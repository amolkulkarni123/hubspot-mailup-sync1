// SUITE 13: INDUSTRY QUEUE (v6.7 MAILUP DISPATCH)
// ═══════════════════════════════════════════════════════════════
section("SUITE 13: Industry-Sequential Dispatch Logic (v6.7)");

function buildIndustryQueue(rows) {
  const queue = {};
  rows.forEach((row, i) => {
    const status = row[COLUMNS_CONTACTS.STATUS - 1];
    if (status === "Pending" || status === "Failed") {
      const industry = (row[COLUMNS_CONTACTS.INDUSTRY - 1] || "General").trim() || "General";
      if (!queue[industry]) queue[industry] = [];
      queue[industry].push({ index: i + 2, row });
    }
  });
  return queue;
}

test("Industry Queue", "Pending rows are grouped by industry", () => {
  const rows = [
    makeContactRow({ industry: "Tech" }),
    makeContactRow({ email: "b@b.com", industry: "Finance" }),
    makeContactRow({ email: "c@c.com", industry: "Tech" })
  ];
  rows[0][9] = "Pending";
  rows[1][9] = "Pending";
  rows[2][9] = "Pending";
  const q = buildIndustryQueue(rows);
  assertEqual(q["Tech"].length, 2);
  assertEqual(q["Finance"].length, 1);
});

test("Industry Queue", "Success rows excluded from queue", () => {
  const row = makeContactRow({ industry: "Tech" });
  row[9] = "Success";
  const q = buildIndustryQueue([row]);
  assertEqual(Object.keys(q).length, 0);
});

test("Industry Queue", "Failed rows included in queue", () => {
  const row = makeContactRow({ industry: "Health" });
  row[9] = "Failed";
  const q = buildIndustryQueue([row]);
  assert("Health" in q);
});

test("Industry Queue", "Empty industry defaults to 'General'", () => {
  const row = makeContactRow({ industry: "" });
  row[9] = "Pending";
  const q = buildIndustryQueue([row]);
  assert("General" in q);
});

test("Industry Queue", "Whitespace-only industry defaults to 'General'", () => {
  const row = makeContactRow({ industry: "   " });
  row[9] = "Pending";
  const q = buildIndustryQueue([row]);
  assert("General" in q);
});

test("Industry Queue", "Total pending count preserved", () => {
  const rows = Array.from({ length: 10 }, (_, i) => {
    const r = makeContactRow({ email: `u${i}@x.com`, industry: `Ind_${i % 3}` });
    r[9] = "Pending";
    return r;
  });
  const q = buildIndustryQueue(rows);
  const total = Object.values(q).reduce((s, a) => s + a.length, 0);
  assertEqual(total, 10);
});


