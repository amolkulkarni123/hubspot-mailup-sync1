test("Edge Cases", "Segment map key 'ai' matches 'ai_automation' tag", () => {
  const tag = "ai_automation";
  let matched = false;
  for (const key of Object.keys(SEGMENT_MAP)) {
    if (tag.includes(key)) { matched = true; break; }
  }
  assert(matched, "'ai' key should match 'ai_automation' tag");
});

test("Edge Cases", "Segment map key order matters — 'ai' before 'analytics'", () => {
  // 'ai' appears before 'analytics' in SEGMENT_MAP
  const keys = Object.keys(SEGMENT_MAP);
  assert(keys.indexOf("ai") < keys.indexOf("analytics"),
    "ai should come before analytics to prevent 'ai' matching 'main' before 'analytics'");
});

test("Edge Cases", "Tag 'main' does NOT falsely match 'ai' segment (word boundary fix)", () => {
  // 'main'.includes('ai') = true (old bug). Word-boundary regex fixes this.
  const tag = "main";
  const matched = new RegExp(`(^|[_\\-\\s,])ai([_\\-\\s,]|$)`).test(tag) || tag === "ai";
  assert(!matched, "'main' should NOT match the 'ai' segment key after word-boundary fix");
});

