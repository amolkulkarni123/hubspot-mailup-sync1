section("SUITE 7: Gap Detection / Composite Score Logic");

function computeComposite(avgScore, activityCount) {
  return (avgScore * GAP_DETECTION_CONFIG.SCORE_WEIGHT) +
         (activityCount * 10 * GAP_DETECTION_CONFIG.ACTIVITY_WEIGHT);
}

test("Gap Detection", "High score + pending status + enough activity = high impact", () => {
  // score=85, activity=6: composite = 85*0.6 + 6*10*0.4 = 51 + 24 = 75 ✅
  const composite = computeComposite(85, 6);
  assert(85 >= GAP_DETECTION_CONFIG.MIN_SCORE);
  assert(GAP_DETECTION_CONFIG.TARGET_STATUSES.includes("Pending"));
  assert(composite >= GAP_DETECTION_CONFIG.MIN_COMPOSITE_SCORE, `Composite ${composite} < ${GAP_DETECTION_CONFIG.MIN_COMPOSITE_SCORE}`);
});

test("Gap Detection", "Score below MIN_SCORE not flagged", () => {
  assert(79 < GAP_DETECTION_CONFIG.MIN_SCORE);
});

test("Gap Detection", "Success status not a target", () => {
  assert(!GAP_DETECTION_CONFIG.TARGET_STATUSES.includes("Success"));
});

test("Gap Detection", "Cold status is a target", () => {
  assert(GAP_DETECTION_CONFIG.TARGET_STATUSES.includes("Cold"));
});

test("Gap Detection", "Unqualified status is a target", () => {
  assert(GAP_DETECTION_CONFIG.TARGET_STATUSES.includes("Unqualified"));
});

test("Gap Detection", "Composite score weights sum to 1.0", () => {
  const sum = GAP_DETECTION_CONFIG.SCORE_WEIGHT + GAP_DETECTION_CONFIG.ACTIVITY_WEIGHT;
  assertEqual(sum, 1.0);
});

test("Gap Detection", "Low composite score not flagged", () => {
  const composite = computeComposite(80, 0); // 48 < 75
  assert(composite < GAP_DETECTION_CONFIG.MIN_COMPOSITE_SCORE);
});

test("Gap Detection", "Zero activity still can meet composite with high score", () => {
  const composite = computeComposite(90, 0); // 54 < 75 → not flagged
  assert(composite < GAP_DETECTION_CONFIG.MIN_COMPOSITE_SCORE, 
    "Score 90 with 0 activity should not meet composite threshold");
});

test("Gap Detection", "Score 80 + 3 activities = composite 60 → fails threshold", () => {
  const composite = computeComposite(80, 3); // 48 + 12 = 60 < 75
  assert(composite < GAP_DETECTION_CONFIG.MIN_COMPOSITE_SCORE);
});

test("Gap Detection", "Score 85 + 5 activities = composite 71 → fails threshold", () => {
  const composite = computeComposite(85, 5); // 51 + 20 = 71 < 75
  assert(composite < GAP_DETECTION_CONFIG.MIN_COMPOSITE_SCORE);
});

test("Gap Detection", "Score 85 + 6 activities = composite 75 → meets threshold", () => {
  const composite = computeComposite(85, 6); // 51 + 24 = 75 >= 75
  assert(composite >= GAP_DETECTION_CONFIG.MIN_COMPOSITE_SCORE);
});


