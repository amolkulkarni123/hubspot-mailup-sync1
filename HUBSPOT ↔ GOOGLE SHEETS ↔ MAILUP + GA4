      if (email && avgScore) behaviorMap[email] = { activityCount: row[COLUMNS_BEHAVIOR.ACTIVITY_COUNT-1], avgScore, primaryTag: row[COLUMNS_BEHAVIOR.PRIMARY_TAG-1] };
    });

