    lock.waitLock(10000);

    const row = sheet.getRange(rowIndex, 1, 1, COLUMN_HEADERS_CONTACTS.length).getValues()[0];
    const hsContactId = String(row[COLUMNS_CONTACTS.HS_CONTACT_ID - 1] || "").trim();

    if (!hsContactId) {
      logger.log("SKIP", { rowIndex, reason: "No HS Contact ID in column 18" });
      return;
    }

    const email = (row[COLUMNS_CONTACTS.EMAIL - 1] || "").trim();
    if (!isValidEmail(email)) {
      sheet.getRange(rowIndex, COLUMNS_CONTACTS.MESSAGE).setValue("Push failed: invalid email in row");
      logger.log("INVALID_EMAIL", { rowIndex, email });
      return;
    }

    const properties = {
      firstname: (row[COLUMNS_CONTACTS.FIRST_NAME - 1] || "").trim(),
      lastname:  (row[COLUMNS_CONTACTS.LAST_NAME  - 1] || "").trim(),
      company:   (row[COLUMNS_CONTACTS.COMPANY    - 1] || "").trim(),
      industry:  (row[COLUMNS_CONTACTS.INDUSTRY   - 1] || "").trim()
    };

    const success = updateHubSpotContact(hsContactId, properties, logger);

    if (success) {
      sheet.getRange(rowIndex, COLUMNS_CONTACTS.MESSAGE)
        .setValue("✅ Pushed to HubSpot: " + new Date().toLocaleTimeString());
      logEvent(LOG_LEVELS.SUCCESS, "MANUAL_UPDATE",
        `Row ${rowIndex} (${email}) pushed to HubSpot contact ${hsContactId}`);
    } else {
      sheet.getRange(rowIndex, COLUMNS_CONTACTS.MESSAGE)
        .setValue("❌ Push failed — check Logs sheet");
      logEvent(LOG_LEVELS.ERROR, "MANUAL_UPDATE",
        `Row ${rowIndex} (${email}) push to HubSpot failed`);
    }

  } finally {
    lock.releaseLock();
  }
}

function pushSelectedRowToHubSpot() {
  const ui = SpreadsheetApp.getUi();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const activeSheet = ss.getActiveSheet();

  if (activeSheet.getName() !== CONFIG.SHEET_CONTACTS) {
    ui.alert("⚠️ Please select a row in the Contacts sheet before using this option.");
    return;
  }

  const rowIndex = activeSheet.getActiveRange().getRow();
  if (rowIndex <= 1) {
    ui.alert("⚠️ Please select a data row (not the header row).");
    return;
  }

  pushLocalChangeToHubSpot(rowIndex);
  ui.alert(`✅ Row ${rowIndex} pushed to HubSpot. Check the Message column for status.`);
}

function onEdit(e) {
  try {
    const range = e && e.range;
    if (!range) return;

    const sheet = range.getSheet();
    if (sheet.getName() !== CONFIG.SHEET_CONTACTS) return;

    const editedCol = range.getColumn();
    const PUSHABLE_COLS = new Set([
      COLUMNS_CONTACTS.FIRST_NAME,
      COLUMNS_CONTACTS.LAST_NAME,
      COLUMNS_CONTACTS.COMPANY,
      COLUMNS_CONTACTS.INDUSTRY
    ]);
    if (!PUSHABLE_COLS.has(editedCol)) return;

    const rowIndex = range.getRow();
    if (rowIndex <= 1) return;

    const debounceKey = `EDIT_DEBOUNCE_R${rowIndex}`;
    const props = PropertiesService.getScriptProperties();
    const lastFired = parseInt(props.getProperty(debounceKey) || "0");
    if (Date.now() - lastFired < 2000) return;
    props.setProperty(debounceKey, String(Date.now()));

    try {
      pushLocalChangeToHubSpot(rowIndex);
    } catch (authErr) {
      if (authErr.message && authErr.message.includes("authoriz")) {
        logEvent(LOG_LEVELS.WARN, "ON_EDIT",
          `Row ${rowIndex}: onEdit must be installed as an Installable Trigger. Run Setup → Setup Time Triggers.`);
      } else {
        throw authErr;
      }
    }

  } catch (err) {
    console.error("onEdit error:", err.message);
  }
}

