// ============================================================
// WEBHOOK RECEIVER — doPost (preserved from v7.2)
// ============================================================

function doPost(e) {
  const lock = LockService.getScriptLock();
  const lockAcquired = lock.tryLock(10000);
  if (!lockAcquired) {
    logEvent(LOG_LEVELS.WARN, "WEBHOOK", "Lock timeout — returning 503 for HubSpot retry");
    return ContentService.createTextOutput(JSON.stringify({ status: "retry", message: "Server busy" }))
      .setMimeType(ContentService.MimeType.JSON);
  }

  try {
    const rawBody = e.postData.contents;

    if (!verifyHubSpotSignature(e, rawBody)) {
      logEvent(LOG_LEVELS.WARN, "WEBHOOK", "Signature verification failed — request rejected");
      return ContentService.createTextOutput(JSON.stringify({ status: "unauthorized" }))
        .setMimeType(ContentService.MimeType.JSON);
    }

    const events = JSON.parse(rawBody);
    if (!Array.isArray(events) || events.length === 0) {
      return ContentService.createTextOutput(JSON.stringify({ status: "ok", processed: 0 }))
        .setMimeType(ContentService.MimeType.JSON);
    }

    logEvent(LOG_LEVELS.INFO, "WEBHOOK", `Received ${events.length} events`);
    const result = processHubSpotWebhookBatch(events);

    return ContentService.createTextOutput(JSON.stringify({ status: "ok", ...result }))
      .setMimeType(ContentService.MimeType.JSON);

  } catch (err) {
    logEvent(LOG_LEVELS.ERROR, "WEBHOOK", `doPost error: ${err.message}`);
    return ContentService.createTextOutput(JSON.stringify({ status: "error", message: err.message }))
      .setMimeType(ContentService.MimeType.JSON);
  } finally {
    lock.releaseLock();
  }
}

function verifyHubSpotSignature(e, rawBody) {
  const secret = CONFIG.hubspot_webhook_secret;
  if (!secret) {
    logEvent(LOG_LEVELS.WARN, "WEBHOOK", "HUBSPOT_WEBHOOK_SECRET not set — skipping signature check");
    return true;
  }

  try {
    const signature = e.parameter["X-HubSpot-Signature-v3"] ||
      (e.headers && e.headers["X-Hubspot-Signature-V3"]) || "";
    if (!signature) return false;

    const timestamp = e.parameter["X-HubSpot-Request-Timestamp"] ||
      (e.headers && e.headers["X-Hubspot-Request-Timestamp"]) || "";

    if (timestamp && (Date.now() - parseInt(timestamp)) > 300000) return false;

    const sourceString = secret + "POST" + e.parameter.url + rawBody + timestamp;
    const expected = Utilities.computeHmacSha256Signature(sourceString, secret)
      .map(b => ('0' + (b & 0xFF).toString(16)).slice(-2)).join('');

    return expected === signature;
  } catch (err) {
    logEvent(LOG_LEVELS.ERROR, "WEBHOOK", `Signature verify error: ${err.message}`);
    return false;
  }
}

function processHubSpotWebhookBatch(events) {
  const eventsSheet = getOrCreateSheet(CONFIG.SHEET_EVENTS, COLUMN_HEADERS_EVENTS);
  const processedEventIds = getProcessedEventIds();

  let created = 0, updated = 0, deleted = 0, skipped = 0;

  events.forEach(event => {
    const eventId = String(event.eventId || "");

    if (eventId && processedEventIds.has(eventId)) {
      skipped++;
      return;
    }

    let result = "unknown";
    try {
      const type = event.subscriptionType || "";
      const objectId = String(event.objectId || "");

      if (type === "contact.creation") {
        handleContactCreate(objectId);
        created++;
        result = "created";
      } else if (type === "contact.propertyChange") {
        handleContactUpdate(objectId, event.propertyName, event.propertyValue);
        updated++;
        result = "updated";
      } else if (type === "contact.deletion") {
        handleContactDelete(objectId);
        deleted++;
        result = "deleted";
      } else {
        result = "unhandled_type";
        skipped++;
      }

      eventsSheet.appendRow([
        new Date(), eventId, type, objectId,
        event.propertyName || "", event.propertyValue || "",
        true, result
      ]);

      if (eventId) processedEventIds.add(eventId);

    } catch (err) {
      logEvent(LOG_LEVELS.ERROR, "WEBHOOK_EVENT", `Failed event ${eventId}: ${err.message}`);
      eventsSheet.appendRow([
        new Date(), eventId, event.subscriptionType || "", event.objectId || "",
        event.propertyName || "", event.propertyValue || "",
        false, `ERROR: ${err.message.substring(0, 100)}`
      ]);
      skipped++;
    }
  });

  saveProcessedEventIds(processedEventIds);

  logEvent(LOG_LEVELS.SUCCESS, "WEBHOOK", `Batch done: created=${created} updated=${updated} deleted=${deleted} skipped=${skipped}`);
  return { created, updated, deleted, skipped };
}

function getProcessedEventIds() {
  const raw = PropertiesService.getScriptProperties().getProperty("PROCESSED_EVENT_IDS") || "[]";
  return new Set(JSON.parse(raw));
}

function saveProcessedEventIds(set) {
  const arr = [...set].slice(-400);
  PropertiesService.getScriptProperties().setProperty("PROCESSED_EVENT_IDS", JSON.stringify(arr));
}

