      if (b.avgScore >= GAP_DETECTION_CONFIG.MIN_SCORE && GAP_DETECTION_CONFIG.TARGET_STATUSES.includes(status) && composite >= GAP_DETECTION_CONFIG.MIN_COMPOSITE_SCORE) {
        detectedRows.push(idx+2);
        insightsSheet.appendRow([new Date(), email, status, Math.round(b.avgScore), b.primaryTag||"interested", "High Intent + Low Status", "Nurture / Re-engage", new Date()]);
