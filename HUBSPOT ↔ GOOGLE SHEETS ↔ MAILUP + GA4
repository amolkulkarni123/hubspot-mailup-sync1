function aggregateSignalsByLead() {
  const activitySheet = getOrCreateSheet(CONFIG.SHEET_ACTIVITY, COLUMN_HEADERS_ACTIVITY);
  const behaviorSheet = getOrCreateSheet(CONFIG.SHEET_BEHAVIOR, COLUMN_HEADERS_BEHAVIOR);
  const logger = new Logger("AGGREGATION");

  try {
    const activityData = activitySheet.getDataRange().getValues();
    const behaviorData = behaviorSheet.getLastRow() > 1 ? behaviorSheet.getDataRange().getValues() : [];

    const existingBehavior = {};
    if (behaviorData.length > 1) {
      behaviorData.slice(1).forEach((row, idx) => {
        const email = (row[COLUMNS_BEHAVIOR.EMAIL - 1] || "").trim().toLowerCase();
        existingBehavior[email] = idx + 2;
      });
    }

    const aggregateMap = {};
    activityData.slice(1).forEach(row => {
      const email = (row[COLUMNS_ACTIVITY.CONTACT_EMAIL - 1] || "").trim().toLowerCase();
      if (!email) return;
      if (!aggregateMap[email]) aggregateMap[email] = { scores: [], tags: [], dates: [], count: 0 };
      aggregateMap[email].count++;
      const score = row[COLUMNS_ACTIVITY.AI_SCORE - 1];
      const tag   = row[COLUMNS_ACTIVITY.AI_TAG - 1];
      const date  = row[COLUMNS_ACTIVITY.ACTIVITY_DATE - 1];
      if (score) aggregateMap[email].scores.push(score);
      if (tag)   aggregateMap[email].tags.push(tag);
      if (date)  aggregateMap[email].dates.push(new Date(date));
    });

    const summaryUpdates = [], newRows = [];
    Object.keys(aggregateMap).forEach(email => {
      const agg = aggregateMap[email];
      const avgScore = agg.scores.length > 0 ? Math.round(agg.scores.reduce((a,b)=>a+b,0)/agg.scores.length) : 0;
      const primaryTag = agg.tags.length > 0 ? agg.tags[0] : "unknown";
      const allTags = [...new Set(agg.tags)].join(", ");
      const lastDate = agg.dates.length > 0 ? new Date(Math.max(...agg.dates.map(d=>d.getTime()))) : new Date();
      let interestLevel = "Low";
      if (agg.count >= 3 && avgScore >= 70) interestLevel = "High";
      else if (agg.count >= 2 || avgScore >= 60) interestLevel = "Medium";
      const rowData = [email, agg.count, avgScore, primaryTag, allTags, interestLevel, lastDate, new Date()];
      if (existingBehavior[email]) summaryUpdates.push({ rowIndex: existingBehavior[email], data: rowData });
      else newRows.push(rowData);
    });

    summaryUpdates.forEach(u => behaviorSheet.getRange(u.rowIndex, 1, 1, u.data.length).setValues([u.data]));
    if (newRows.length > 0) behaviorSheet.getRange(behaviorSheet.getLastRow()+1, 1, newRows.length, newRows[0].length).setValues(newRows);

    logger.log("COMPLETE", { unique_leads: Object.keys(aggregateMap).length, updated: summaryUpdates.length, new: newRows.length });

  } catch (error) { logger.log("ERROR", { error: error.message }); throw error; }
}

