function registerHubSpotWebhooks() {
  const ui = SpreadsheetApp.getUi();
  const appId    = CONFIG.hubspot_app_id;
  const portalId = CONFIG.hubspot_portal_id;
  const webAppUrl = getProp("WEB_APP_URL");

  if (!appId || !portalId) {
    ui.alert("❌ Missing HUBSPOT_APP_ID or HUBSPOT_PORTAL_ID in script properties.");
    return;
  }
  if (!webAppUrl) {
    ui.alert("❌ Missing WEB_APP_URL in script properties.\n\nDeploy this script as a Web App first, then save the URL as WEB_APP_URL.");
    return;
  }

  const logger = new Logger("WEBHOOK_SETUP");

  try {
    const settingsUrl = `${CONFIG.HUBSPOT_API_V3}/webhooks/v3/${appId}/settings`;
    const settingsRes = UrlFetchApp.fetch(settingsUrl, {
      method: "PUT",
      headers: {
        "Authorization": `Bearer ${CONFIG.hub_token}`,
        "Content-Type": "application/json"
      },
      payload: JSON.stringify({ targetUrl: webAppUrl, maxConcurrentRequests: 10 }),
      muteHttpExceptions: true
    });
    logger.log("SETTINGS", { code: settingsRes.getResponseCode() });
  } catch (e) {
    logger.log("SETTINGS_ERROR", e.message);
  }

  const subscriptions = [
    { eventType: "contact.creation",       propertyName: null },
    { eventType: "contact.deletion",       propertyName: null },
    { eventType: "contact.propertyChange", propertyName: "email" },
    { eventType: "contact.propertyChange", propertyName: "firstname" },
    { eventType: "contact.propertyChange", propertyName: "lastname" },
    { eventType: "contact.propertyChange", propertyName: "company" },
    { eventType: "contact.propertyChange", propertyName: "jobtitle" },
    { eventType: "contact.propertyChange", propertyName: "industry" },
    { eventType: "contact.propertyChange", propertyName: "country" },
    { eventType: "contact.propertyChange", propertyName: "hs_lead_status" }
  ];

  let registered = 0;
  const subUrl = `${CONFIG.HUBSPOT_API_V3}/webhooks/v3/${appId}/subscriptions`;

  subscriptions.forEach(sub => {
    try {
      const payload = { eventType: sub.eventType, active: true };
      if (sub.propertyName) payload.propertyName = sub.propertyName;

      const res = UrlFetchApp.fetch(subUrl, {
        method: "POST",
        headers: { "Authorization": `Bearer ${CONFIG.hub_token}`, "Content-Type": "application/json" },
        payload: JSON.stringify(payload),
        muteHttpExceptions: true
      });

      const code = res.getResponseCode();
      if (code === 201 || code === 200) registered++;
      logger.log("SUBSCRIBE", { type: sub.eventType, property: sub.propertyName, code });

    } catch (e) {
      logger.log("SUBSCRIBE_ERROR", { type: sub.eventType, error: e.message });
    }
  });

  ui.alert(`✅ Webhook registration complete.\n\nRegistered: ${registered}/${subscriptions.length} subscriptions\nTarget URL: ${webAppUrl}`);
}

