function handleContactCreate(contactId) {
  const contactData = fetchHubSpotContact(contactId);
  if (!contactData) {
    logEvent(LOG_LEVELS.WARN, "EVENT_CREATE", `Could not fetch contact ${contactId}`);
    return;
  }
  const sheet = getOrCreateSheet(CONFIG.SHEET_CONTACTS, COLUMN_HEADERS_CONTACTS);
  upsertContactRow(sheet, contactData, contactId);
  logEvent(LOG_LEVELS.SUCCESS, "EVENT_CREATE", `Contact ${contactId} (${contactData.email}) upserted`);
}

function handleContactUpdate(contactId, propertyName, newValue) {
  if (!TRACKED_HS_PROPERTIES.has(propertyName)) return;

  const sheet = getOrCreateSheet(CONFIG.SHEET_CONTACTS, COLUMN_HEADERS_CONTACTS);
  const rowIndex = getContactRowByHSId(sheet, contactId);

  if (!rowIndex) {
    handleContactCreate(contactId);
    return;
  }

  const colMap = {
    firstname:       COLUMNS_CONTACTS.FIRST_NAME,
    lastname:        COLUMNS_CONTACTS.LAST_NAME,
    email:           COLUMNS_CONTACTS.EMAIL,
    company:         COLUMNS_CONTACTS.COMPANY,
    jobtitle:        COLUMNS_CONTACTS.JOB_TITLE,
    industry:        COLUMNS_CONTACTS.INDUSTRY,
    country:         COLUMNS_CONTACTS.COUNTRY,
    continent:       COLUMNS_CONTACTS.CONTINENT,
    hs_lead_status:  COLUMNS_CONTACTS.REGION
  };

  const col = colMap[propertyName];
  if (col) {
    sheet.getRange(rowIndex, col).setValue(newValue || "");
    logEvent(LOG_LEVELS.INFO, "EVENT_UPDATE", `Contact ${contactId} — ${propertyName} = "${newValue}"`);
  }
}

function handleContactDelete(contactId) {
  const sheet = getOrCreateSheet(CONFIG.SHEET_CONTACTS, COLUMN_HEADERS_CONTACTS);
  const rowIndex = getContactRowByHSId(sheet, contactId);

  if (!rowIndex) {
    logEvent(LOG_LEVELS.WARN, "EVENT_DELETE", `Contact ${contactId} not found in sheet — no action`);
    return;
  }

  sheet.getRange(rowIndex, COLUMNS_CONTACTS.STATUS).setValue("Deleted");
  sheet.getRange(rowIndex, COLUMNS_CONTACTS.MESSAGE).setValue("Deleted in HubSpot");
  sheet.getRange(rowIndex, 1, 1, COLUMN_HEADERS_CONTACTS.length).setBackground("#f5f5f5");
  logEvent(LOG_LEVELS.INFO, "EVENT_DELETE", `Contact ${contactId} soft-deleted`);
}

// ============================================================
// MAILUP → SHEETS BACK-SYNC (preserved from v7.2)
// ============================================================

function syncMailUpToSheets() {
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(10000)) {
    logEvent(LOG_LEVELS.WARN, "MAILUP_BACKSYNC", "Lock timeout — skipping this cycle");
    return;
  }
  const sheet = getOrCreateSheet(CONFIG.SHEET_CONTACTS, COLUMN_HEADERS_CONTACTS);
  const logger = new Logger("MAILUP_BACKSYNC");

  try {
    const token = getMailUpTokenCached();
    if (!token) { logger.log("ERROR", "No MailUp token"); return; }

    let totalUpdated = 0;

    const unsubscribed = fetchMailUpRecipientsByStatus(token, MAILUP_STATUS.UNSUBSCRIBED, logger);
    unsubscribed.forEach(r => {
      const rowIndex = getContactRowByEmail(sheet, r.Email);
      if (!rowIndex) return;
      sheet.getRange(rowIndex, COLUMNS_CONTACTS.STATUS).setValue("Unsubscribed");
      sheet.getRange(rowIndex, COLUMNS_CONTACTS.MESSAGE).setValue("Unsubscribed in MailUp");
      totalUpdated++;
    });

    const bounced = fetchMailUpRecipientsByStatus(token, MAILUP_STATUS.BOUNCED, logger);
    bounced.forEach(r => {
      const rowIndex = getContactRowByEmail(sheet, r.Email);
      if (!rowIndex) return;
      sheet.getRange(rowIndex, COLUMNS_CONTACTS.STATUS).setValue("Bounced");
      sheet.getRange(rowIndex, COLUMNS_CONTACTS.MESSAGE).setValue("Email bounced in MailUp");
      totalUpdated++;
    });

    SpreadsheetApp.flush();
    logger.log("COMPLETE", { unsubscribed: unsubscribed.length, bounced: bounced.length, sheet_updated: totalUpdated });

    if (totalUpdated > 0) syncSheetsToHubSpot();

  } catch (err) {
    logger.log("ERROR", { error: err.message });
  } finally {
    lock.releaseLock();
  }
}

function fetchMailUpRecipientsByStatus(token, statusCode, logger) {
  const results = [];
  let pageNum = 0;
  const pageSize = 100;

  while (true) {
    try {
      const url = `${CONFIG.MAILUP_API_BASE}/List/${CONFIG.mailup_list_id}/Recipients/${statusCode}?pageSize=${pageSize}&pageNumber=${pageNum}`;
      const res = UrlFetchApp.fetch(url, {
        method: "GET",
        headers: { "Authorization": "Bearer " + token },
        muteHttpExceptions: true
      });

      if (res.getResponseCode() !== 200) break;
      const json = JSON.parse(res.getContentText());
      const items = json.Items || [];
      if (items.length === 0) break;

      results.push(...items);
      if (items.length < pageSize) break;
      pageNum++;

    } catch (e) {
      logger.log("MAILUP_FETCH_ERROR", { status: statusCode, error: e.message });
      break;
    }
  }

  return results;
}

// ============================================================
// SHEETS → HUBSPOT WRITE-BACK (preserved from v7.2)
// ============================================================

function syncSheetsToHubSpot() {
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(10000)) {
    logEvent(LOG_LEVELS.WARN, "HS_WRITEBACK", "Lock timeout — skipping this cycle");
    return;
  }
  const sheet = getOrCreateSheet(CONFIG.SHEET_CONTACTS, COLUMN_HEADERS_CONTACTS);
  const backSyncSheet = getOrCreateSheet(CONFIG.SHEET_BACKSYNC, COLUMN_HEADERS_BACKSYNC);
  const logger = new Logger("HS_WRITEBACK");

  try {
    const lastRow = sheet.getLastRow();
    if (lastRow <= 1) return;

    const data = sheet.getRange(2, 1, lastRow - 1, COLUMN_HEADERS_CONTACTS.length).getValues();
    let updated = 0;

    for (const row of data) {
      if (!isTimeRemaining(30000)) break;

      const status = row[COLUMNS_CONTACTS.STATUS - 1];
      const email = (row[COLUMNS_CONTACTS.EMAIL - 1] || "").trim();
      const hsContactId = String(row[COLUMNS_CONTACTS.HS_CONTACT_ID - 1] || "").trim();

      if (!email || !hsContactId) continue;
      if (status !== "Unsubscribed" && status !== "Bounced") continue;

      const alreadySynced = checkBackSyncAlreadyDone(backSyncSheet, email);
      if (alreadySynced) continue;

      const properties = {};
      if (status === "Unsubscribed") {
        properties["hs_email_optout"] = true;
        properties["hs_lead_status"] = "UNQUALIFIED";
      } else if (status === "Bounced") {
        properties["hs_email_bounced"] = true;
        properties["hs_lead_status"] = "UNQUALIFIED";
      }

      const success = updateHubSpotContact(hsContactId, properties, logger);

      backSyncSheet.appendRow([
        new Date(), email, status, success,
        success ? "HubSpot updated" : "HubSpot update failed"
      ]);

      if (success) updated++;
    }

    logger.log("COMPLETE", { updated });

  } catch (err) {
    logger.log("ERROR", { error: err.message });
  } finally {
    lock.releaseLock();
  }
}

function checkBackSyncAlreadyDone(backSyncSheet, email) {
  if (backSyncSheet.getLastRow() < 2) return false;
  const emails = backSyncSheet.getRange(2, 2, backSyncSheet.getLastRow() - 1, 1).getValues();
  return emails.some(r => String(r[0]).toLowerCase() === email.toLowerCase());
}

function updateHubSpotContact(contactId, properties, logger) {
  try {
    const url = `${CONFIG.HUBSPOT_API_BASE}/contacts/${contactId}`;
    const res = UrlFetchApp.fetch(url, {
      method: "PATCH",
      headers: {
        "Authorization": `Bearer ${CONFIG.hub_token}`,
        "Content-Type": "application/json"
      },
      payload: JSON.stringify({ properties }),
      muteHttpExceptions: true
    });

    const code = res.getResponseCode();
    if (code === 200) return true;

    logger.log("HS_PATCH_FAILED", { contactId, code, body: res.getContentText().substring(0, 100) });
    return false;

  } catch (e) {
    logger.log("HS_PATCH_ERROR", { contactId, error: e.message });
    return false;
  }
}

