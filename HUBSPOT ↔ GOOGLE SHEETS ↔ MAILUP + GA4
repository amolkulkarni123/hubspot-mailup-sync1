function runInfinityFetch() {
  const sheet = getOrCreateSheet(CONFIG.SHEET_CONTACTS, COLUMN_HEADERS_CONTACTS);
  const state = STATE.get();
  const existingEmails = getExistingEmails(sheet);
  const logger = new Logger("IMPORT");

  try {
    let cursor = state.hs_cursor || null;
    let hasMore = true;
    let sortingBuffer = [];
    let totalImported = state.hs_total || 0;

    const props = ["email","firstname","lastname","company","jobtitle","industry","country","hs_lead_status","continent"];

    while (hasMore && isTimeRemaining(60000)) {
      let url = `${CONFIG.HUBSPOT_API_BASE}/contacts?limit=${CONFIG.HUBSPOT_BATCH_SIZE}&properties=${props.join(",")}`;
      if (cursor) url += `&after=${cursor}`;

      const response = fetchWithBackoff(url);
      if (!response || !response.results) break;

      response.results.forEach(contact => {
        const email = (contact.properties.email || "").trim().toLowerCase();
        const industry = (contact.properties.industry || "Unclassified").trim();
        if (email && !existingEmails.has(email)) {
          sortingBuffer.push({
            industry,
            data: buildContactRow(contact)
          });
          existingEmails.add(email);
          totalImported++;
        }
      });

      if (sortingBuffer.length >= CONFIG.SHEET_WRITE_BUFFER) {
        sortingBuffer.sort((a, b) => a.industry.localeCompare(b.industry));
        safeWriteToSheet(sheet, sortingBuffer.map(i => i.data), sheet.getLastRow() + 1);
        logger.log("BATCH_FLUSH", { rows: sortingBuffer.length, total: totalImported });
        sortingBuffer = [];
      }

      if (response.paging && response.paging.next) {
        cursor = response.paging.next.after;
        STATE.update("hs_cursor", cursor);
      } else {
        hasMore = false;
        STATE.delete("hs_cursor");
      }
    }

    if (sortingBuffer.length > 0) {
      sortingBuffer.sort((a, b) => a.industry.localeCompare(b.industry));
      safeWriteToSheet(sheet, sortingBuffer.map(i => i.data), sheet.getLastRow() + 1);
    }

    STATE.update("hs_total", totalImported);
    STATE.update("last_import", new Date().toISOString());
    logger.log("COMPLETE", { total: totalImported });

  } catch (error) {
    logger.log("ERROR", { error: error.message });
    throw error;
  }
}

function ingestHubSpotSignals() {
  const sheet = getOrCreateSheet(CONFIG.SHEET_ACTIVITY, COLUMN_HEADERS_ACTIVITY);
  const existingIds = getExistingSignalIds(sheet);
  const logger = new Logger("SIGNALS");

  try {
    let cursor = STATE.get().signal_cursor || null;
    let hasMore = true;
    let buffer = [];
    let totalNew = 0;

    const props = ["hs_communication_channel_type","hs_communication_logged_from","hs_timestamp","hs_communication_subject"];

    while (hasMore && isTimeRemaining(60000)) {
      let url = `${CONFIG.HUBSPOT_API_BASE}/communications?limit=${CONFIG.SIGNAL_BATCH_SIZE}&properties=${props.join(",")}&associations=contacts`;
      if (cursor) url += `&after=${cursor}`;

      const response = fetchWithBackoff(url);
      if (!response || !response.results) break;

      response.results.forEach(sig => {
        if (existingIds.has(sig.id)) return;
        const validation = validateSignal(sig);
        if (!validation.valid) { logger.log("VALIDATION_FAILED", { signalId: sig.id, error: validation.error }); return; }

        const sanitized = validation.sanitized;
        let contactEmail = sanitized.loggedFrom;

        if (sig.associations?.contacts?.results?.length > 0) {
          const resolved = fetchContactEmail(sig.associations.contacts.results[0].id, logger);
          if (resolved) { contactEmail = resolved; }
        }

        buffer.push([sanitized.timestamp, sanitized.loggedFrom, sig.id, contactEmail, "HubSpot", sanitized.channelType, sanitized.subject, "", "", "", new Date()]);
        existingIds.add(sig.id);
        totalNew++;
      });

      if (buffer.length >= CONFIG.SHEET_WRITE_BUFFER) {
        safeWriteToSheet(sheet, buffer, sheet.getLastRow() + 1);
        logger.log("BATCH_FLUSH", { rows: buffer.length });
        buffer = [];
      }

      if (response.paging?.next) { cursor = response.paging.next.after; STATE.update("signal_cursor", cursor); }
      else { hasMore = false; STATE.delete("signal_cursor"); }
    }

    if (buffer.length > 0) safeWriteToSheet(sheet, buffer, sheet.getLastRow() + 1);
    logger.log("COMPLETE", { new_signals: totalNew });

  } catch (error) { logger.log("ERROR", { error: error.message }); throw error; }
}

