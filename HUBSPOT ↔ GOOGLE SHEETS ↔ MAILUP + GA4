function runAIInferenceEnhanced() {
  const behaviorSheet  = getOrCreateSheet(CONFIG.SHEET_BEHAVIOR,  COLUMN_HEADERS_BEHAVIOR);
  const contactsSheet  = getOrCreateSheet(CONFIG.SHEET_CONTACTS,  COLUMN_HEADERS_CONTACTS);
  const logger = new Logger("AI_ENGINE_GA4");
  
  if (!CONFIG.gemini_key) {
    logger.log("ERROR", "Gemini API key not configured");
    return;
  }

  try {
    const behaviorData = behaviorSheet.getDataRange().getValues();
    const contactsData = contactsSheet.getDataRange().getValues();
    
    const emailToContactRow = {};
    contactsData.forEach((row, idx) => {
      const email = (row[COLUMNS_CONTACTS.EMAIL-1]||"").trim().toLowerCase();
      if (email) emailToContactRow[email] = idx + 1;
    });

    const pending = [];
    for (let i = 1; i < behaviorData.length; i++) {
      if (pending.length >= CONFIG.MAX_AI_PER_RUN) break;
      
      const avgScore = behaviorData[i][COLUMNS_BEHAVIOR.AVG_SCORE-1];
      
      if (!avgScore || avgScore === 0 || avgScore < 30) {
        pending.push({
          index: i+1,
          email: behaviorData[i][COLUMNS_BEHAVIOR.EMAIL-1],
          summary: {
            activityCount: behaviorData[i][COLUMNS_BEHAVIOR.ACTIVITY_COUNT-1],
            primaryTag: behaviorData[i][COLUMNS_BEHAVIOR.PRIMARY_TAG-1],
            allTags: behaviorData[i][COLUMNS_BEHAVIOR.ALL_TAGS-1],
            interestLevel: behaviorData[i][COLUMNS_BEHAVIOR.INTEREST_LEVEL-1]
          }
        });
      }
    }

    if (pending.length === 0) {
      logger.log("INFO", "No pending summaries for AI");
      return;
    }

    let processed = 0;
    const aiBudgetStart = Date.now();

    for (let i = 0; i < pending.length; i += CONFIG.AI_BATCH_SIZE) {
      if (!isTimeRemaining(30000) || (Date.now()-aiBudgetStart) > 90000) break;
      
      const batch = pending.slice(i, i+CONFIG.AI_BATCH_SIZE);
      
      let results = inferBatchWithGA4Context(batch, logger);
      
      if (results.rateLimited) {
        Utilities.sleep(CONFIG.GEMINI_RATE_LIMIT_PAUSE);
        results = inferBatchWithGA4Context(batch, logger);
      }
      
      results.data.forEach((result, idx) => {
        if (result.valid) {
          behaviorSheet.getRange(batch[idx].index, COLUMNS_BEHAVIOR.AVG_SCORE).setValue(result.score);
          
          const crow = emailToContactRow[batch[idx].email];
          if (crow) {
            contactsSheet.getRange(crow, COLUMNS_CONTACTS.AI_SCORE).setValue(result.score);
            contactsSheet.getRange(crow, COLUMNS_CONTACTS.AI_TAG).setValue(result.tag);
          }
          processed++;
        }
      });
      
      SpreadsheetApp.flush();
    }

    logger.log("COMPLETE", { processed, total: pending.length, ga4_enhanced: true });

  } catch (error) {
    logger.log("ERROR", { error: error.message });
    throw error;
  }
}

