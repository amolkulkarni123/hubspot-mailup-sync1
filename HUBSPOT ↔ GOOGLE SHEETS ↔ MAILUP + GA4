function fullReconciliation() {
  const logger = new Logger("RECONCILE");
  logger.log("START", "Beginning full tri-platform reconciliation");

  const sheet = getOrCreateSheet(CONFIG.SHEET_CONTACTS, COLUMN_HEADERS_CONTACTS);
  let hsAdded = 0, hsUpdated = 0;

  try {
    logger.log("PHASE_1", "Comparing HubSpot contacts vs Sheets");

    const hsContacts = fetchAllHubSpotContacts(logger);
    const emailToRowIndex = buildEmailIndex(sheet);
    const hsIdToRowIndex  = buildHSIdIndex(sheet);

    for (const contact of hsContacts) {
      if (!isTimeRemaining(60000)) {
        logger.log("TIMEOUT", "Stopping Phase 1 early");
        break;
      }

      const hsId = String(contact.id);
      const email = (contact.properties.email || "").trim().toLowerCase();
      if (!email) continue;

      const existingRow = hsIdToRowIndex[hsId] || emailToRowIndex[email];

      if (!existingRow) {
        upsertContactRow(sheet, mapHSPropertiesToRow(contact), hsId);
        hsAdded++;
      } else {
        const sheetRow = sheet.getRange(existingRow, 1, 1, COLUMN_HEADERS_CONTACTS.length).getValues()[0];
        if (isContactRowStale(sheetRow, contact)) {
          patchContactRow(sheet, existingRow, contact);
          hsUpdated++;
        }
      }
    }

    logger.log("PHASE_1_DONE", { added: hsAdded, updated: hsUpdated });

    if (isTimeRemaining(90000)) {
      logger.log("PHASE_2", "Reconciling MailUp statuses with Sheets");
      syncMailUpToSheets();
    }

    if (isTimeRemaining(60000)) {
      logger.log("PHASE_3", "Re-pushing contacts missing from MailUp");
      pushSheetToMailUp();
    }

    logger.log("COMPLETE", { hs_added: hsAdded, hs_updated: hsUpdated });

  } catch (err) {
    logger.log("ERROR", { error: err.message });
  }
}

function isContactRowStale(sheetRow, hsContact) {
  const p = hsContact.properties;
  const checks = [
    [COLUMNS_CONTACTS.FIRST_NAME - 1, p.firstname || ""],
    [COLUMNS_CONTACTS.LAST_NAME - 1,  p.lastname  || ""],
    [COLUMNS_CONTACTS.COMPANY - 1,    p.company   || ""],
    [COLUMNS_CONTACTS.INDUSTRY - 1,   p.industry  || ""],
    [COLUMNS_CONTACTS.COUNTRY - 1,    p.country   || ""]
  ];
  return checks.some(([col, val]) => String(sheetRow[col] || "").trim() !== val.trim());
}

function patchContactRow(sheet, rowIndex, hsContact) {
  const p = hsContact.properties;
  const updates = [
    [COLUMNS_CONTACTS.FIRST_NAME, p.firstname || ""],
    [COLUMNS_CONTACTS.LAST_NAME,  p.lastname  || ""],
    [COLUMNS_CONTACTS.COMPANY,    p.company   || ""],
    [COLUMNS_CONTACTS.JOB_TITLE,  p.jobtitle  || ""],
    [COLUMNS_CONTACTS.INDUSTRY,   p.industry  || ""],
    [COLUMNS_CONTACTS.COUNTRY,    p.country   || ""],
    [COLUMNS_CONTACTS.CONTINENT,  p.continent || ""]
  ];
  updates.forEach(([col, val]) => sheet.getRange(rowIndex, col).setValue(val));
}

function fetchAllHubSpotContacts(logger) {
  const props = ["email","firstname","lastname","company","jobtitle","industry","country","hs_lead_status","continent"];
  const contacts = [];
  let cursor = null;

  while (true) {
    let url = `${CONFIG.HUBSPOT_API_BASE}/contacts?limit=100&properties=${props.join(",")}`;
    if (cursor) url += `&after=${cursor}`;

    const response = fetchWithBackoff(url);
    if (!response || !response.results) break;

    contacts.push(...response.results);
    logger.log("FETCH_PAGE", { count: contacts.length });

    if (response.paging && response.paging.next) {
      cursor = response.paging.next.after;
    } else {
      break;
    }
  }

  return contacts;
}

