/**
 * Pulls website behavioral data from Google Analytics 4.
 * Creates synthetic signals in the Raw Activity sheet.
 * These signals are then aggregated and scored like HubSpot signals.
 */
function ingestGA4Signals() {
  const logger = new Logger("GA4_INGEST");
  
  if (!GA4_CONFIG.property_id) {
    logger.log("ERROR", "GA4_PROPERTY_ID not configured");
    return;
  }
  
  try {
    const token = getGA4AccessToken();
    if (!token) {
      logger.log("ERROR", "Failed to get GA4 access token");
      return;
    }
    
    const endDate = new Date();
    const startDate = new Date();
    startDate.setDate(startDate.getDate() - GA4_CONFIG.lookback_days);
    
    logger.log("INFO", `Pulling GA4 data from ${startDate.toISOString()} to ${endDate.toISOString()}`);
    
    const engagementData = fetchGA4UserEngagement(token, startDate, endDate, logger);
    const eventData = fetchGA4Events(token, startDate, endDate, logger);
    
    const signals = transformGA4ToSignals(engagementData, eventData, logger);
    
    const activitySheet = getOrCreateSheet(CONFIG.SHEET_ACTIVITY, COLUMN_HEADERS_ACTIVITY);
    const existingIds = getExistingSignalIds(activitySheet);
    
    const newSignals = signals.filter(s => !existingIds.has(s.signalId));
    
    if (newSignals.length > 0) {
      const rows = newSignals.map(s => [
        s.timestamp,
        s.email,
        s.signalId,
        s.email,
        "GA4",
        s.channelType,
        s.subject,
        "",
        "",
        "",
        new Date()
      ]);
      
      safeWriteToSheet(activitySheet, rows, activitySheet.getLastRow() + 1);
      logger.log("SUCCESS", `Imported ${newSignals.length} GA4 signals`);
    } else {
      logger.log("INFO", "No new GA4 signals to import");
    }
    
  } catch (error) {
    logger.log("ERROR", { error: error.message });
    throw error;
  }
}

function fetchGA4UserEngagement(token, startDate, endDate, logger) {
  const url = `https://analyticsdata.googleapis.com/v1beta/properties/${GA4_CONFIG.property_id}:runReport`;
  
  const requestBody = {
    dateRanges: [{
      startDate: formatDateForGA4(startDate),
      endDate: formatDateForGA4(endDate)
    }],
    dimensions: [
      { name: "customUser:email" },
      { name: "date" },
      { name: "country" },
      { name: "deviceCategory" }
    ],
    metrics: [
      { name: "sessions" },
      { name: "screenPageViews" },
      { name: "userEngagementDuration" },
      { name: "bounceRate" },
      { name: "averageSessionDuration" }
    ],
    dimensionFilter: {
      filter: {
        fieldName: "customUser:email",
        stringFilter: {
          matchType: "PARTIAL_REGEXP",
          value: "@.*\\."
        }
      }
    },
    limit: 10000
  };
  
  try {
    const response = UrlFetchApp.fetch(url, {
      method: "POST",
      headers: {
        "Authorization": "Bearer " + token,
        "Content-Type": "application/json"
      },
      payload: JSON.stringify(requestBody),
      muteHttpExceptions: true
    });
    
    const code = response.getResponseCode();
    if (code !== 200) {
      logger.log("GA4_API_ERROR", { code, body: response.getContentText().substring(0, 200) });
      return [];
    }
    
    const data = JSON.parse(response.getContentText());
    return parseGA4Response(data, logger);
    
  } catch (e) {
    logger.log("GA4_FETCH_ERROR", e.message);
    return [];
  }
}

function fetchGA4Events(token, startDate, endDate, logger) {
  const url = `https://analyticsdata.googleapis.com/v1beta/properties/${GA4_CONFIG.property_id}:runReport`;
  
  const requestBody = {
    dateRanges: [{
      startDate: formatDateForGA4(startDate),
      endDate: formatDateForGA4(endDate)
    }],
    dimensions: [
      { name: "customUser:email" },
      { name: "eventName" },
      { name: "date" }
    ],
    metrics: [
      { name: "eventCount" }
    ],
    dimensionFilter: {
      andGroup: {
        expressions: [
          {
            filter: {
              fieldName: "customUser:email",
              stringFilter: { matchType: "PARTIAL_REGEXP", value: "@.*\\." }
            }
          },
          {
            orGroup: {
              expressions: [
                { filter: { fieldName: "eventName", stringFilter: { value: "form_submit" } } },
                { filter: { fieldName: "eventName", stringFilter: { value: "file_download" } } },
                { filter: { fieldName: "eventName", stringFilter: { value: "purchase" } } },
                { filter: { fieldName: "eventName", stringFilter: { value: "sign_up" } } },
                { filter: { fieldName: "eventName", stringFilter: { value: "contact_submit" } } }
              ]
            }
          }
        ]
      }
    },
    limit: 5000
  };
  
  try {
    const response = UrlFetchApp.fetch(url, {
      method: "POST",
      headers: {
        "Authorization": "Bearer " + token,
        "Content-Type": "application/json"
      },
      payload: JSON.stringify(requestBody),
      muteHttpExceptions: true
    });
    
    if (response.getResponseCode() !== 200) return [];
    
    const data = JSON.parse(response.getContentText());
    return parseGA4EventResponse(data, logger);
    
  } catch (e) {
    logger.log("GA4_EVENT_ERROR", e.message);
    return [];
  }
}

function parseGA4Response(data, logger) {
  const results = [];
  
  if (!data.rows || data.rows.length === 0) {
    logger.log("INFO", "No GA4 engagement data found");
    return results;
  }
  
  data.rows.forEach(row => {
    try {
      const email = row.dimensionValues[0].value;
      const date = row.dimensionValues[1].value;
      const country = row.dimensionValues[2].value;
      const device = row.dimensionValues[3].value;
      
      const sessions = parseInt(row.metricValues[0].value) || 0;
      const pageViews = parseInt(row.metricValues[1].value) || 0;
      const engagementSeconds = parseInt(row.metricValues[2].value) || 0;
      const bounceRate = parseFloat(row.metricValues[3].value) || 0;
      const avgSessionDuration = parseFloat(row.metricValues[4].value) || 0;
      
      if (!isValidEmail(email)) return;
      
      results.push({
        email: email.toLowerCase().trim(),
        date: parseGA4Date(date),
        country,
        device,
        sessions,
        pageViews,
        engagementSeconds,
        bounceRate,
        avgSessionDuration
      });
      
    } catch (e) {
      logger.log("PARSE_ERROR", e.message);
    }
  });
  
  logger.log("INFO", `Parsed ${results.length} engagement records`);
  return results;
}

function parseGA4EventResponse(data, logger) {
  const results = [];
  
  if (!data.rows) return results;
  
  data.rows.forEach(row => {
    try {
      const email = row.dimensionValues[0].value;
      const eventName = row.dimensionValues[1].value;
      const date = row.dimensionValues[2].value;
      const eventCount = parseInt(row.metricValues[0].value) || 0;
      
      if (!isValidEmail(email)) return;
      
      results.push({
        email: email.toLowerCase().trim(),
        eventName,
        date: parseGA4Date(date),
        eventCount
      });
      
    } catch (e) {
      logger.log("EVENT_PARSE_ERROR", e.message);
    }
  });
  
  return results;
}

function transformGA4ToSignals(engagementData, eventData, logger) {
  const signals = [];
  
  engagementData.forEach(record => {
    let channelType = "website_visit";
    let subject = "";
    
    if (record.engagementSeconds >= GA4_CONFIG.thresholds.high_engagement_seconds &&
        record.pageViews >= GA4_CONFIG.thresholds.high_page_views) {
      channelType = "website_high_engagement";
      subject = `Deep exploration: ${record.pageViews} pages, ${Math.round(record.engagementSeconds/60)}min`;
    }
    else if (record.engagementSeconds >= GA4_CONFIG.thresholds.medium_engagement_seconds ||
             record.pageViews >= GA4_CONFIG.thresholds.medium_page_views) {
      channelType = "website_medium_engagement";
      subject = `Active session: ${record.pageViews} pages, ${Math.round(record.engagementSeconds/60)}min`;
    }
    else if (record.bounceRate > 0.7) {
      channelType = "website_bounce";
      subject = `Quick visit: bounced after ${record.pageViews} pages`;
    }
    else {
      subject = `Website visit: ${record.pageViews} pages from ${record.country}`;
    }
    
    const signalId = `ga4_${record.email}_${record.date.getTime()}_${record.sessions}`;
    
    signals.push({
      signalId,
      email: record.email,
      timestamp: record.date,
      channelType,
      subject,
      country: record.country,
      device: record.device
    });
  });
  
  eventData.forEach(record => {
    let channelType = "website_conversion";
    let subject = "";
    
    switch (record.eventName) {
      case "form_submit":
      case "contact_submit":
        subject = `Form submission (${record.eventCount}x)`;
        channelType = "website_form_submit";
        break;
      case "file_download":
        subject = `Downloaded resource (${record.eventCount}x)`;
        channelType = "website_download";
        break;
      case "purchase":
        subject = `Purchase event (${record.eventCount}x)`;
        channelType = "website_purchase";
        break;
      case "sign_up":
        subject = `Account signup (${record.eventCount}x)`;
        channelType = "website_signup";
        break;
      default:
        subject = `${record.eventName} (${record.eventCount}x)`;
    }
    
    const signalId = `ga4_event_${record.email}_${record.eventName}_${record.date.getTime()}`;
    
    signals.push({
      signalId,
      email: record.email,
      timestamp: record.date,
      channelType,
      subject
    });
  });
  
  logger.log("INFO", `Created ${signals.length} signals from GA4 data`);
  return signals;
}

function getGA4AccessToken() {
  const props = PropertiesService.getScriptProperties();
  
  const cached = props.getProperty("GA4_ACCESS_TOKEN");
  const expiry = parseInt(props.getProperty("GA4_TOKEN_EXPIRY") || "0");
  
  if (cached && Date.now() < expiry) {
    return cached;
  }
  
  try {
    const response = UrlFetchApp.fetch("https://oauth2.googleapis.com/token", {
      method: "POST",
      headers: { "Content-Type": "application/x-www-form-urlencoded" },
      payload: {
        client_id: GA4_CONFIG.client_id,
        client_secret: GA4_CONFIG.client_secret,
        refresh_token: GA4_CONFIG.refresh_token,
        grant_type: "refresh_token"
      },
      muteHttpExceptions: true
    });
    
    if (response.getResponseCode() !== 200) {
      logEvent(LOG_LEVELS.ERROR, "GA4_AUTH", "Token refresh failed: " + response.getContentText());
      return null;
    }
    
    const data = JSON.parse(response.getContentText());
    const accessToken = data.access_token;
    const expiresIn = data.expires_in || 3600;
    
    props.setProperty("GA4_ACCESS_TOKEN", accessToken);
    props.setProperty("GA4_TOKEN_EXPIRY", String(Date.now() + (expiresIn - 600) * 1000));
    
    return accessToken;
    
  } catch (e) {
    logEvent(LOG_LEVELS.ERROR, "GA4_AUTH", "OAuth error: " + e.message);
    return null;
  }
}

function formatDateForGA4(date) {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}

function parseGA4Date(dateString) {
  const year = parseInt(dateString.substring(0, 4));
  const month = parseInt(dateString.substring(4, 6)) - 1;
  const day = parseInt(dateString.substring(6, 8));
  return new Date(year, month, day);
}

