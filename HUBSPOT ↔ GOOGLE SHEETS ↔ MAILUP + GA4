}

function fetchWithBackoff(url, maxRetries = CONFIG.MAX_RETRIES) {
  for (let attempt = 1; attempt <= maxRetries; attempt++) {
    try {
      const res = UrlFetchApp.fetch(url, {
        method: "GET",
        headers: { Authorization: `Bearer ${CONFIG.hub_token}` },
        muteHttpExceptions: true,
        timeout: 30000
      });
      const code = res.getResponseCode();
      if (code === 200) return JSON.parse(res.getContentText());
      if (code === 429 || code >= 400) {
        if (attempt === maxRetries) return null;
        Utilities.sleep(CONFIG.RETRY_DELAY_BASE * Math.pow(2, attempt-1));
      }
    } catch (e) {
      if (attempt === maxRetries) return null;
      Utilities.sleep(CONFIG.RETRY_DELAY_BASE * Math.pow(2, attempt-1));
    }
  }
  return null;
}

function getMailUpTokenCached() {
  const props = PropertiesService.getScriptProperties();
  const cached = props.getProperty("MAILUP_TOKEN");
  const expiry = parseInt(props.getProperty("MAILUP_TOKEN_EXP") || "0");
  if (cached && Date.now() < expiry) return cached;
  try {
    const auth = Utilities.base64Encode(CONFIG.mailup_client_id + ':' + CONFIG.mailup_client_secret);
    const payload = `grant_type=password&username=${encodeURIComponent(CONFIG.mailup_username)}&password=${encodeURIComponent(CONFIG.mailup_password)}`;
    const res = UrlFetchApp.fetch(CONFIG.MAILUP_TOKEN_URL, {
      method: "POST",
      headers: { "Authorization": "Basic "+auth, "Content-Type": "application/x-www-form-urlencoded" },
      payload, muteHttpExceptions: true, timeout: 20000
    });
    if (res.getResponseCode() !== 200) { logEvent(LOG_LEVELS.ERROR, "AUTH", `MailUp auth failed (${res.getResponseCode()})`); return null; }
    const json = JSON.parse(res.getContentText());
    if (!json.access_token) { logEvent(LOG_LEVELS.ERROR, "AUTH", "No token in response"); return null; }
    props.setProperty("MAILUP_TOKEN", json.access_token);
    props.setProperty("MAILUP_TOKEN_EXP", (Date.now() + 50*60*1000).toString());
    return json.access_token;
  } catch (error) { logEvent(LOG_LEVELS.ERROR, "AUTH", error.message); return null; }
}

function parseGeminiResponse(res) {
  try {
    const text = res.getContentText();
    if (!text) return { valid: false, error: "Empty response" };
    const json = JSON.parse(text);
    if (json.error) return { valid: false, error: json.error.message || "API error" };
    if (!json.candidates || json.candidates.length === 0) return { valid: false, error: "No candidates" };
    const part = json.candidates[0]?.content?.parts?.[0];
    if (!part?.text) return { valid: false, error: "No text in part" };
    const cleanText = part.text.replace(/```json\s*/g, '').replace(/```\s*/g, '').trim();
    const aiJson = JSON.parse(cleanText);
    if (typeof aiJson.score !== 'number' || aiJson.score < 1 || aiJson.score > 100) return { valid: false, error: "Invalid score" };
    if (!aiJson.tag || typeof aiJson.tag !== 'string') return { valid: false, error: "Invalid tag" };
    return { valid: true, score: Math.round(aiJson.score), tag: aiJson.tag.substring(0, 50) };
  } catch (e) { return { valid: false, error: e.message }; }
}

const STATE = {
  get:    ()        => JSON.parse(PropertiesService.getScriptProperties().getProperty("APP_STATE") || "{}"),
  set:    (state)   => PropertiesService.getScriptProperties().setProperty("APP_STATE", JSON.stringify(state)),
  update: (key, val)=> { const s = STATE.get(); s[key] = val; STATE.set(s); },
  delete: (key)     => { const s = STATE.get(); delete s[key]; STATE.set(s); }
};

class Logger {
  constructor(module) { this.module = module; }
  log(event, data) {
    const msg = typeof data === 'object' ? JSON.stringify(data) : data;
    console.log(`[${this.module}] ${event}: ${msg}`);
    logEvent(LOG_LEVELS.INFO, this.module, `${event}: ${msg}`);
  }
}

function safeWriteToSheet(sheet, rows, startRow) {
  if (rows.length === 0) return true;
  try { sheet.getRange(startRow, 1, rows.length, rows[0].length).setValues(rows); return true; }
  catch (e) { logEvent(LOG_LEVELS.ERROR, "SHEET", `Write failed: ${e.message}`); return false; }
}

function getExistingEmails(sheet) {
  const set = new Set();
  if (sheet.getLastRow() < 2) return set;
  try {
    sheet.getRange(2, COLUMNS_CONTACTS.EMAIL, sheet.getLastRow()-1, 1).getValues()
      .forEach(r => { if (r[0]) set.add(String(r[0]).trim().toLowerCase()); });
  } catch (e) { console.error("Failed to load existing emails:", e.message); }
  return set;
}

function getExistingSignalIds(sheet) {
  const set = new Set();
  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return set;
  try {
    const rowsToLoad = Math.min(CONFIG.SIGNAL_LOOKBACK_ROWS, lastRow-1);
    const startRow = Math.max(2, lastRow-rowsToLoad+1);
    sheet.getRange(startRow, COLUMNS_ACTIVITY.SIGNAL_ID, rowsToLoad, 1).getValues()
      .forEach(r => { if (r[0]) set.add(String(r[0]).trim()); });
  } catch (e) { console.error("Failed to load signal IDs:", e.message); }
  return set;
}

function pushToDLQ(rowIndex, rowData, reason) {
  try {
    const dlqSheet = getOrCreateSheet(CONFIG.SHEET_DLQ, ["Row Index","Email","Reason","Timestamp","Retry Count"]);
    dlqSheet.appendRow([rowIndex, rowData[COLUMNS_CONTACTS.EMAIL-1], reason, new Date(), 0]);
  } catch (e) { console.error("Failed to push to DLQ:", e.message); }
}

function isTimeRemaining(buffer = 30000) {
  return (Date.now() - SCRIPT_START_TIME) < (CONFIG.MAX_TIME_MS - buffer);
}

function getOrCreateSheet(name, headers) {
  let sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(name);
  if (!sheet) {
    sheet = SpreadsheetApp.getActiveSpreadsheet().insertSheet(name);
    if (headers && headers.length > 0) { sheet.appendRow(headers); sheet.setFrozenRows(1); }
  }
  return sheet;
}

function logEvent(level, type, message) {
  try {
    const logsSheet = getOrCreateSheet(CONFIG.SHEET_LOGS, ["Timestamp","Level","Type","Message"]);
    logsSheet.appendRow([new Date(), level, type, message]);
    if (logsSheet.getLastRow() > 2000) logsSheet.deleteRows(2, 500);
  } catch (e) { console.error("Failed to log event:", e.message); }
}

function getProp(key) {
  return PropertiesService.getScriptProperties().getProperty(key);
}

function showLogs()           { SpreadsheetApp.getActiveSpreadsheet().setActiveSheet(getOrCreateSheet(CONFIG.SHEET_LOGS)); }
function showInsights()       { SpreadsheetApp.getActiveSpreadsheet().setActiveSheet(getOrCreateSheet(CONFIG.SHEET_INSIGHTS, COLUMN_HEADERS_INSIGHTS)); }
