function resetEverything() {
  const ui = SpreadsheetApp.getUi();
  if (ui.alert("⚠️ This will delete ALL data and triggers. Are you sure?", ui.ButtonSet.YES_NO) !== ui.Button.YES) return;
  removeAllTriggers();
  PropertiesService.getScriptProperties().deleteAllProperties();
  STATE.set({});
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  [CONFIG.SHEET_DLQ, CONFIG.SHEET_EVENTS, CONFIG.SHEET_BACKSYNC].forEach(name => {
    const s = ss.getSheetByName(name); if (s) ss.deleteSheet(s);
  });
  ui.alert("✅ Reset complete. Re-configure script properties and run Setup > Register Webhooks.");
}
