      payload: JSON.stringify({
        contents: [{
          parts: [{ text: prompt }]
        }],
        generationConfig: {
          response_mime_type: "application/json",
          maxOutputTokens: 200,
          temperature: 0.3
        }
      }),
      muteHttpExceptions: true
    };
  });
  
  try {
    const responses = UrlFetchApp.fetchAll(requests);
    const results = [];
    let rateLimited = false;
    
    responses.forEach(res => {
      if (res.getResponseCode() === 429) {
        rateLimited = true;
        results.push({ valid: false, error: "Rate limited" });
        return;
      }
      results.push(parseGeminiResponse(res));
    });
    
    return { rateLimited, data: results };
    
  } catch (error) {
    logger.log("FETCH_ERROR", error.message);
    return {
      rateLimited: false,
      data: rowsData.map(() => ({ valid: false, error: error.message }))
    };
  }
}

function extractGA4Context(email) {
  try {
    const activitySheet = getOrCreateSheet(CONFIG.SHEET_ACTIVITY, COLUMN_HEADERS_ACTIVITY);
    const data = activitySheet.getDataRange().getValues();
    
    const ga4Signals = data.filter(row => 
      row[COLUMNS_ACTIVITY.SOURCE - 1] === "GA4" &&
      String(row[COLUMNS_ACTIVITY.CONTACT_EMAIL - 1]).toLowerCase() === email.toLowerCase()
    );
    
    if (ga4Signals.length === 0) return null;
    
    let totalSessions = 0;
    let totalPageViews = 0;
    let totalEngagementTime = 0;
    let conversions = 0;
    let lastVisit = null;
    
    ga4Signals.forEach(signal => {
      const subject = signal[COLUMNS_ACTIVITY.SUBJECT - 1] || "";
      const date = signal[COLUMNS_ACTIVITY.ACTIVITY_DATE - 1];
      
      const pageMatch = subject.match(/(\d+) pages/);
      const timeMatch = subject.match(/(\d+)min/);
      
      if (pageMatch) totalPageViews += parseInt(pageMatch[1]);
      if (timeMatch) totalEngagementTime += parseInt(timeMatch[1]);
      
      if (subject.includes("Form submission") || 
          subject.includes("Downloaded") ||
          subject.includes("Purchase") ||
          subject.includes("signup")) {
        conversions++;
      }
      
      totalSessions++;
      
      if (!lastVisit || date > lastVisit) {
        lastVisit = date;
      }
    });
    
    const avgPagesPerSession = totalSessions > 0 ? Math.round(totalPageViews / totalSessions) : 0;
    const avgTimePerSession = totalSessions > 0 ? Math.round(totalEngagementTime / totalSessions) : 0;
    
    const daysSinceVisit = lastVisit ? 
      Math.round((new Date() - new Date(lastVisit)) / (1000 * 60 * 60 * 24)) : 
      999;
    
    return `- Total Sessions: ${totalSessions}
- Avg Pages/Session: ${avgPagesPerSession}
- Avg Time/Session: ${avgTimePerSession} minutes
- Conversions: ${conversions} (forms, downloads, signups)
- Last Visit: ${daysSinceVisit} days ago
- Engagement Pattern: ${categorizeEngagement(totalSessions, avgPagesPerSession, avgTimePerSession, conversions)}`;
    
  } catch (e) {
    console.error("GA4 context extraction failed:", e.message);
    return null;
  }
}

function categorizeEngagement(sessions, avgPages, avgTime, conversions) {
  if (conversions >= 2) return "High-intent buyer (multiple conversions)";
  if (conversions >= 1 && sessions >= 3) return "Engaged prospect (converted + repeat visitor)";
  if (sessions >= 5 && avgPages >= 4) return "Active researcher (frequent deep visits)";
  if (sessions >= 3 && avgTime >= 3) return "Interested evaluator (moderate engagement)";
  if (avgPages <= 2 && avgTime <= 1) return "Low engagement (bounce/quick exit pattern)";
  return "Standard visitor";
}

