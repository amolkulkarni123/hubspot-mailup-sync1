// ============================================================
// PHASE 7: INDUSTRY-SEQUENTIAL MAILUP DISPATCH (v6.7)
// ============================================================

/**
 * Pushes Pending contacts to MailUp, dispatching one Industry group at a time.
 * v6.7 change: groups pending rows by industry into industryQueue,
 * then iterates industry-by-industry for logical, sequential dispatch.
 * Full v6.3 validation, DLQ, and status updates are preserved.
 */
function pushSheetToMailUp() {
  const sheet = getOrCreateSheet(CONFIG.SHEET_CONTACTS, COLUMN_HEADERS_CONTACTS);
  const logger = new Logger("PUSH");

  try {
    if (!isTimeRemaining(90000)) {
      logger.log("TIMEOUT", "Not enough time for push");
      return;
    }

    const token = getMailUpTokenCached();
    if (!token) {
      logger.log("ERROR", "Failed to get MailUp token");
      return;
    }

    const lastRow = sheet.getLastRow();
    if (lastRow <= 1) {
      logger.log("INFO", "No data to push");
      return;
    }

    const allData = sheet.getRange(2, 1, lastRow - 1, COLUMN_HEADERS_CONTACTS.length).getValues();

    // ✅ v6.7: Group Pending/Failed records by Industry
    const industryQueue = {};
    for (let i = 0; i < allData.length; i++) {
      const status = allData[i][COLUMNS_CONTACTS.STATUS - 1];
      if (status === "Pending" || status === "Failed") {
        const industry = (allData[i][COLUMNS_CONTACTS.INDUSTRY - 1] || "General").trim() || "General";
        if (!industryQueue[industry]) industryQueue[industry] = [];
        industryQueue[industry].push({ index: i + 2, row: allData[i] });
      }
    }

    const totalPending = Object.values(industryQueue).reduce((sum, arr) => sum + arr.length, 0);
    if (totalPending === 0) {
      logger.log("INFO", "No pending records");
      return;
    }

    logger.log("INFO", `Found ${totalPending} pending records across ${Object.keys(industryQueue).length} industries`);

    let successCount = 0;
    let failureCount = 0;

    // ✅ v6.7: Dispatch one industry at a time
    for (const industry in industryQueue) {
      if (!isTimeRemaining(30000)) {
        logger.log("TIMEOUT", `Stopped before finishing industry: ${industry}`);
        break;
      }

      const batch = industryQueue[industry];
      logger.log("INDUSTRY_START", { industry, count: batch.length });

      for (let j = 0; j < batch.length; j += CONFIG.MAILUP_BATCH_SIZE) {
        if (!isTimeRemaining(20000)) break;

        const subBatch = batch.slice(j, j + CONFIG.MAILUP_BATCH_SIZE);
        const results = pushBatch(subBatch, token, logger);

        results.forEach((result, idx) => {
          const rowIndex = subBatch[idx].index;
          sheet.getRange(rowIndex, COLUMNS_CONTACTS.STATUS).setValue(result.status);
          sheet.getRange(rowIndex, COLUMNS_CONTACTS.MESSAGE).setValue(result.message);

          if (result.status === "Success") {
            sheet.getRange(rowIndex, COLUMNS_CONTACTS.MAILUP_ID).setValue(result.mailupId);
            sheet.getRange(rowIndex, COLUMNS_CONTACTS.PUSHED_AT).setValue(new Date());
            successCount++;
          } else if (result.status === "Failed") {
            failureCount++;
            pushToDLQ(rowIndex, subBatch[idx].row, result.message);
          }
        });

        SpreadsheetApp.flush();
      }

      logger.log("INDUSTRY_DONE", { industry, success: successCount, failed: failureCount });
    }

    logger.log("COMPLETE", { success: successCount, failed: failureCount, total: totalPending });

  } catch (error) {
    logger.log("ERROR", { error: error.message });
    throw error;
  }
}

function pushBatch(rowsData, token, logger) {
  const requests = [];

  rowsData.forEach(item => {
    const validation = validateContactForMailUp(item.row);
    if (!validation.valid) return;

    const sanitized = validation.sanitized;
    requests.push({
      url: `${CONFIG.MAILUP_API_BASE}/List/${CONFIG.mailup_list_id}/Recipient`,
      method: "POST",
      headers: { "Authorization": "Bearer " + token, "Content-Type": "application/json" },
      payload: JSON.stringify({ "Email": sanitized.email, "Fields": buildMailUpFields(sanitized) }),
      muteHttpExceptions: true
    });
  });

  if (requests.length === 0) return [];

  const responses = UrlFetchApp.fetchAll(requests);
  return responses.map((res, idx) => {
    const code = res.getResponseCode();
    const body = res.getContentText();
    const email = rowsData[idx].row[COLUMNS_CONTACTS.EMAIL - 1];

    if (code >= 200 && code < 300) {
      logger.log("PUSH_SUCCESS", { email, code });
      return { status: "Success", message: "Synced to MailUp", mailupId: body };
    } else if (code === 429) {
      logger.log("RATE_LIMIT", { email });
      return { status: "Pending", message: "Rate limited - will retry next cycle" };
    } else if (code === 409) {
      logger.log("DUPLICATE", { email });
      return { status: "Failed", message: "Duplicate email in MailUp list" };
    } else {
      logger.log("PUSH_FAILED", { email, code, response: body.substring(0, 100) });
      return { status: "Failed", message: `API Error ${code}: ${body.substring(0, 50)}` };
    }
  });
}

function retryFailedPushes() {
  const sheet = getOrCreateSheet(CONFIG.SHEET_CONTACTS, COLUMN_HEADERS_CONTACTS);
  const logger = new Logger("RETRY");

  try {
    const lastRow = sheet.getLastRow();
    if (lastRow <= 1) return;

    const allData = sheet.getRange(2, 1, lastRow - 1, COLUMN_HEADERS_CONTACTS.length).getValues();
    const failed = [];

    for (let i = 0; i < allData.length; i++) {
      if (!isTimeRemaining(60000)) break;
      if (allData[i][COLUMNS_CONTACTS.STATUS - 1] === "Failed") {
        failed.push({ index: i + 2, row: allData[i] });
      }
    }

    if (failed.length === 0) { logger.log("INFO", "No failed records to retry"); return; }

    logger.log("START", { count: failed.length });
    const token = getMailUpTokenCached();
    let successCount = 0;

    for (let i = 0; i < failed.length; i += CONFIG.MAILUP_BATCH_SIZE) {
      if (!isTimeRemaining(30000)) break;
      const batch = failed.slice(i, i + CONFIG.MAILUP_BATCH_SIZE);
      const results = pushBatch(batch, token, logger);

      results.forEach((result, idx) => {
        const rowIndex = batch[idx].index;
        sheet.getRange(rowIndex, COLUMNS_CONTACTS.STATUS).setValue(result.status);
        sheet.getRange(rowIndex, COLUMNS_CONTACTS.MESSAGE).setValue(result.message);
        if (result.status === "Success") successCount++;
      });

      SpreadsheetApp.flush();
    }

    logger.log("COMPLETE", { retried: failed.length, success: successCount });

  } catch (error) {
    logger.log("ERROR", { error: error.message });
  }
}

// ============================================================
// VALIDATION & DATA PREPARATION
// ============================================================

function validateContactForMailUp(row) {
  const errors = [];
  const email = (row[COLUMNS_CONTACTS.EMAIL - 1] || "").trim();
  const firstName = (row[COLUMNS_CONTACTS.FIRST_NAME - 1] || "").trim();
  const lastName = (row[COLUMNS_CONTACTS.LAST_NAME - 1] || "").trim();
  const company = (row[COLUMNS_CONTACTS.COMPANY - 1] || "").trim();

  if (!isValidEmail(email)) errors.push("Invalid email format");
  if (!firstName && !lastName) errors.push("At least one name required");
  if (firstName && firstName.length > 100) errors.push("First name too long");
  if (lastName && lastName.length > 100) errors.push("Last name too long");
  if (company && company.length > 255) errors.push("Company too long");

  return {
    valid: errors.length === 0,
    error: errors.join("; "),
    sanitized: {
      email: email.toLowerCase(),
      firstName: firstName.substring(0, 100),
      lastName: lastName.substring(0, 100),
      company: company.substring(0, 255),
      jobTitle: (row[COLUMNS_CONTACTS.JOB_TITLE - 1] || "").trim().substring(0, 100),
      industry: (row[COLUMNS_CONTACTS.INDUSTRY - 1] || "").trim().substring(0, 100),
      country: (row[COLUMNS_CONTACTS.COUNTRY - 1] || "").trim().substring(0, 100),
      region: (row[COLUMNS_CONTACTS.REGION - 1] || "").trim().substring(0, 100),
      continent: (row[COLUMNS_CONTACTS.CONTINENT - 1] || "").trim().substring(0, 100)
    }
  };
}

function buildMailUpFields(sanitized) {
  const fields = [
    { Id: MAILUP_FIELD_IDS.FIRST_NAME, Value: sanitized.firstName },
    { Id: MAILUP_FIELD_IDS.LAST_NAME, Value: sanitized.lastName },
    { Id: MAILUP_FIELD_IDS.COMPANY, Value: sanitized.company }
  ];
  if (sanitized.jobTitle) fields.push({ Id: MAILUP_FIELD_IDS.JOB_TITLE, Value: sanitized.jobTitle });
  if (sanitized.industry) fields.push({ Id: MAILUP_FIELD_IDS.INDUSTRY, Value: sanitized.industry });
  if (sanitized.country) fields.push({ Id: MAILUP_FIELD_IDS.COUNTRY, Value: sanitized.country });
  if (sanitized.region) fields.push({ Id: MAILUP_FIELD_IDS.REGION, Value: sanitized.region });
  if (sanitized.continent) fields.push({ Id: MAILUP_FIELD_IDS.CONTINENT, Value: sanitized.continent });
  return fields;
}

function validateSignal(signal) {
  const errors = [];
  if (!signal.id) errors.push("Missing signal ID");
  if (!signal.properties) errors.push("Missing properties");

  const channelType = signal.properties?.hs_communication_channel_type || "";
  const loggedFrom = signal.properties?.hs_communication_logged_from || "";
  const timestamp = signal.properties?.hs_timestamp;

  if (!channelType) errors.push("Missing channel type");
  if (!loggedFrom) errors.push("Missing logged_from");
  if (!timestamp) errors.push("Missing timestamp");

  const date = new Date(timestamp);
  if (isNaN(date.getTime())) errors.push("Invalid timestamp");

  return {
    valid: errors.length === 0,
    error: errors.join("; "),
    sanitized: {
      channelType: channelType.trim().substring(0, 50),
      loggedFrom: loggedFrom.trim().substring(0, 100),
      subject: (signal.properties?.hs_communication_subject || "").trim().substring(0, 200),
      timestamp: date
    }
  };
}

function isValidEmail(email) {
  if (!email || typeof email !== 'string') return false;
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.trim());
}

