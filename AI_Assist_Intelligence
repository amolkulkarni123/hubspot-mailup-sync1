      <tr><td><strong>📡 Unique Leads (Behavior)</strong></td><td><strong>${behaviorTotal}</strong></td><td>-</td></tr>
      <tr><td><strong>🟡 High-Impact Leads</strong></td><td><strong>${insightsTotal}</strong></td><td>${contactsTotal > 0 ? ((insightsTotal/contactsTotal)*100).toFixed(1) : 0}%</td></tr>
    </table>
    <hr>
    <h3>🆕 v6.7 Features Active</h3>
    <p>✅ Industry-Sorted Ingestion (contacts grouped alphabetically by industry on import)</p>
    <p>✅ Industry-Sequential MailUp Push (dispatches one industry group at a time)</p>
    <h3>💰 Cost Optimization</h3>
    <p>MAX_AI_PER_RUN: <strong>${CONFIG.MAX_AI_PER_RUN}</strong></p>
    <p>Last updated: ${new Date().toLocaleString()}</p>
  `;
  SpreadsheetApp.getUi().showModelessDialog(HtmlService.createHtmlOutput(html), "Sync Statistics v6.7");
}

