function resetEverything() {
  const ui = SpreadsheetApp.getUi();
  if (ui.alert("⚠️ This will delete ALL data. Are you sure?", ui.ButtonSet.YES_NO) !== ui.Button.YES) return;
  PropertiesService.getScriptProperties().deleteAllProperties();
  STATE.set({});
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  [CONFIG.SHEET_DLQ].forEach(name => { const s = ss.getSheetByName(name); if (s) ss.deleteSheet(s); });
  ui.alert("✅ Reset complete");
}
