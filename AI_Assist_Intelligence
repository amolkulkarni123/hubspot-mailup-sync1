      }

      let segment = "General";
      for (const [tagKey, segmentName] of Object.entries(SEGMENT_MAP)) {
        if (tag.includes(tagKey)) { segment = segmentName; break; }
      }
      contactsSheet.getRange(i + 1, COLUMNS_CONTACTS.AI_SEGMENT).setValue(segment);
      segmentedCount++;
    }

    logger.log("COMPLETE", { segmented: segmentedCount, total: data.length - 1 });

  } catch (error) {
    logger.log("ERROR", { error: error.message });
    throw error;
  }
}

