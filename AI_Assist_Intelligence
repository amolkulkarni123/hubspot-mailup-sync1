function assignSegments() {
  const contactsSheet = getOrCreateSheet(CONFIG.SHEET_CONTACTS, COLUMN_HEADERS_CONTACTS);
  const logger = new Logger("SEGMENTATION");

  try {
    const data = contactsSheet.getDataRange().getValues();
    let segmentedCount = 0;

    for (let i = 1; i < data.length; i++) {
      const tag = (data[i][COLUMNS_CONTACTS.AI_TAG - 1] || "").trim().toLowerCase();
      if (!tag) {
        contactsSheet.getRange(i + 1, COLUMNS_CONTACTS.AI_SEGMENT).setValue("Unclassified");
