function ingestHubSpotSignals() {
  const sheet = getOrCreateSheet(CONFIG.SHEET_ACTIVITY, COLUMN_HEADERS_ACTIVITY);
  const existingIds = getExistingSignalIds(sheet);
  const logger = new Logger("SIGNALS");

  try {
    let cursor = STATE.get().signal_cursor || null;
    let hasMore = true;
    let buffer = [];
    let totalNew = 0;

    const props = [
      "hs_communication_channel_type",
      "hs_communication_logged_from",
      "hs_timestamp",
      "hs_communication_subject"
    ];

    while (hasMore && isTimeRemaining(60000)) {
      let url = `${CONFIG.HUBSPOT_API_BASE}/communications?limit=${CONFIG.SIGNAL_BATCH_SIZE}&properties=${props.join(",")}&associations=contacts`;
      if (cursor) url += `&after=${cursor}`;

      const response = fetchWithBackoff(url);
      if (!response || !response.results) break;

      response.results.forEach(sig => {
        if (existingIds.has(sig.id)) return;

        const validation = validateSignal(sig);
        if (!validation.valid) {
          logger.log("VALIDATION_FAILED", { signalId: sig.id, error: validation.error });
          return;
        }

        const sanitized = validation.sanitized;

        // ✅ FIX #12: Get contact email from association
        let contactEmail = sanitized.loggedFrom;
        if (sig.associations && sig.associations.contacts && sig.associations.contacts.results && sig.associations.contacts.results.length > 0) {
          const contactId = sig.associations.contacts.results[0].id;
          const resolved = fetchContactEmail(contactId, logger);
          if (resolved) {
            contactEmail = resolved;
            logger.log("ASSOCIATION_FOUND", { signalId: sig.id, contactId, email: contactEmail });
          }
        }

        buffer.push([
          sanitized.timestamp,
          sanitized.loggedFrom,
          sig.id,
          contactEmail,
          "HubSpot",
          sanitized.channelType,
          sanitized.subject,
          "",
          "",
          "",
          new Date()
        ]);
        existingIds.add(sig.id);
        totalNew++;
      });

      if (buffer.length >= CONFIG.SHEET_WRITE_BUFFER) {
        safeWriteToSheet(sheet, buffer, sheet.getLastRow() + 1);
        logger.log("BATCH_FLUSH", { rows: buffer.length });
        buffer = [];
      }

      if (response.paging && response.paging.next) {
        cursor = response.paging.next.after;
        STATE.update("signal_cursor", cursor);
      } else {
        hasMore = false;
        STATE.delete("signal_cursor");
      }
    }

    if (buffer.length > 0) safeWriteToSheet(sheet, buffer, sheet.getLastRow() + 1);
    logger.log("COMPLETE", { new_signals: totalNew });

  } catch (error) {
    logger.log("ERROR", { error: error.message });
    throw error;
  }
}

function fetchContactEmail(contactId, logger) {
  try {
    const url = `${CONFIG.HUBSPOT_API_BASE}/contacts/${contactId}?properties=email`;
    const response = fetchWithBackoff(url);
    if (response && response.properties && response.properties.email) {
      return response.properties.email.trim().toLowerCase();
    }
    logger.log("CONTACT_NO_EMAIL", { contactId });
    return null;
  } catch (e) {
    logger.log("CONTACT_FETCH_ERROR", { contactId, error: e.message });
    return null;
  }
}

