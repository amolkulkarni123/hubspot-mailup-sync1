function detectHighImpactLeads() {
  const contactsSheet = getOrCreateSheet(CONFIG.SHEET_CONTACTS, COLUMN_HEADERS_CONTACTS);
  const behaviorSheet = getOrCreateSheet(CONFIG.SHEET_BEHAVIOR, COLUMN_HEADERS_BEHAVIOR);
  const insightsSheet = getOrCreateSheet(CONFIG.SHEET_INSIGHTS, COLUMN_HEADERS_INSIGHTS);
  const logger = new Logger("GAP_DETECTION");

  try {
    const contactData = contactsSheet.getDataRange().getValues();
    const behaviorData = behaviorSheet.getDataRange().getValues();

    const behaviorMap = {};
    behaviorData.slice(1).forEach(row => {
      const email = (row[COLUMNS_BEHAVIOR.EMAIL - 1] || "").trim().toLowerCase();
      const avgScore = row[COLUMNS_BEHAVIOR.AVG_SCORE - 1];
      if (email && avgScore) {
        behaviorMap[email] = {
          activityCount: row[COLUMNS_BEHAVIOR.ACTIVITY_COUNT - 1],
          avgScore,
          primaryTag: row[COLUMNS_BEHAVIOR.PRIMARY_TAG - 1]
        };
      }
    });

    const detectedRows = [];

    contactData.slice(1).forEach((row, idx) => {
      const email = (row[COLUMNS_CONTACTS.EMAIL - 1] || "").trim().toLowerCase();
      const status = row[COLUMNS_CONTACTS.STATUS - 1] || "";
      if (!behaviorMap[email]) return;

      const behavior = behaviorMap[email];
      const compositeScore =
        (behavior.avgScore * GAP_DETECTION_CONFIG.SCORE_WEIGHT) +
        (behavior.activityCount * 10 * GAP_DETECTION_CONFIG.ACTIVITY_WEIGHT);

      if (
        behavior.avgScore >= GAP_DETECTION_CONFIG.MIN_SCORE &&
        GAP_DETECTION_CONFIG.TARGET_STATUSES.includes(status) &&
        compositeScore >= GAP_DETECTION_CONFIG.MIN_COMPOSITE_SCORE
      ) {
        detectedRows.push(idx + 2);
        insightsSheet.appendRow([
          new Date(), email, status, Math.round(behavior.avgScore),
          behavior.primaryTag || "interested", "High Intent + Low Status",
          "Nurture / Re-engage", new Date()
        ]);
        logger.log("DETECTED", { email, status, score: Math.round(behavior.avgScore) });
      }
    });

    if (detectedRows.length > 0) {
      batchHighlightRows(contactsSheet, detectedRows, "#fff2cc");
    }

    logger.log("COMPLETE", { detected: detectedRows.length });

  } catch (error) {
    logger.log("ERROR", { error: error.message });
    throw error;
  }
}

