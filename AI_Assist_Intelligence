function aggregateSignalsByLead() {
  const activitySheet = getOrCreateSheet(CONFIG.SHEET_ACTIVITY, COLUMN_HEADERS_ACTIVITY);
  const behaviorSheet = getOrCreateSheet(CONFIG.SHEET_BEHAVIOR, COLUMN_HEADERS_BEHAVIOR);
  const logger = new Logger("AGGREGATION");

  try {
    const activityData = activitySheet.getDataRange().getValues();
    const aggregateMap = {};

    activityData.slice(1).forEach(row => {
      const email = (row[COLUMNS_ACTIVITY.CONTACT_EMAIL - 1] || "").trim().toLowerCase();
      const score = row[COLUMNS_ACTIVITY.AI_SCORE - 1];
      const tag = row[COLUMNS_ACTIVITY.AI_TAG - 1];
      const date = row[COLUMNS_ACTIVITY.ACTIVITY_DATE - 1];

      if (!email) return;

      if (!aggregateMap[email]) {
        aggregateMap[email] = { scores: [], tags: [], dates: [], count: 0 };
      }

      aggregateMap[email].count++;
      if (score) aggregateMap[email].scores.push(score);
      if (tag) aggregateMap[email].tags.push(tag);
      if (date) aggregateMap[email].dates.push(new Date(date));
    });

    const summaryData = [];
    Object.keys(aggregateMap).forEach(email => {
      const agg = aggregateMap[email];
      const avgScore = agg.scores.length > 0
        ? Math.round(agg.scores.reduce((a, b) => a + b, 0) / agg.scores.length)
        : 0;
      const primaryTag = agg.tags.length > 0 ? agg.tags[0] : "unknown";
      const allTags = [...new Set(agg.tags)].join(", ");
      const lastDate = agg.dates.length > 0
        ? new Date(Math.max(...agg.dates.map(d => d.getTime())))
        : new Date();

      let interestLevel = "Low";
      if (agg.count >= 3 && avgScore >= 70) interestLevel = "High";
      else if (agg.count >= 2 || avgScore >= 60) interestLevel = "Medium";

      summaryData.push([email, agg.count, avgScore, primaryTag, allTags, interestLevel, lastDate, new Date()]);
    });

    if (behaviorSheet.getLastRow() > 1) {
      behaviorSheet.deleteRows(2, behaviorSheet.getLastRow() - 1);
    }
    if (summaryData.length > 0) {
      behaviorSheet.getRange(2, 1, summaryData.length, summaryData[0].length).setValues(summaryData);
    }

    logger.log("COMPLETE", {
      unique_leads: Object.keys(aggregateMap).length,
      total_signals: activityData.length - 1,
      avg_signals_per_lead: (Object.values(aggregateMap).reduce((a, b) => a + b.count, 0) / Object.keys(aggregateMap).length).toFixed(1)
    });

  } catch (error) {
    logger.log("ERROR", { error: error.message });
    throw error;
  }
}

