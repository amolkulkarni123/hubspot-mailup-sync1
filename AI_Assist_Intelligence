function runAIInference() {
  const behaviorSheet = getOrCreateSheet(CONFIG.SHEET_BEHAVIOR, COLUMN_HEADERS_BEHAVIOR);
  const contactsSheet = getOrCreateSheet(CONFIG.SHEET_CONTACTS, COLUMN_HEADERS_CONTACTS);
  const logger = new Logger("AI_ENGINE");

  if (!CONFIG.gemini_key) {
    logger.log("ERROR", "Gemini API key not configured");
    return;
  }

  try {
    const behaviorData = behaviorSheet.getDataRange().getValues();
    const contactsData = contactsSheet.getDataRange().getValues();

    const emailToContactRow = {};
    contactsData.forEach((row, idx) => {
      const email = (row[COLUMNS_CONTACTS.EMAIL - 1] || "").trim().toLowerCase();
      if (email) emailToContactRow[email] = idx + 1;
    });

    const pending = [];
    for (let i = 1; i < behaviorData.length; i++) {
      if (pending.length >= CONFIG.MAX_AI_PER_RUN) {
        logger.log("COST_CONTROL", `Reached MAX_AI_PER_RUN (${CONFIG.MAX_AI_PER_RUN}). Stopping.`);
        break;
      }

      const email = behaviorData[i][COLUMNS_BEHAVIOR.EMAIL - 1];
      const avgScore = behaviorData[i][COLUMNS_BEHAVIOR.AVG_SCORE - 1];

      if (!avgScore || avgScore === 0) {
        pending.push({
          index: i + 1,
          email: email,
          summary: {
            activityCount: behaviorData[i][COLUMNS_BEHAVIOR.ACTIVITY_COUNT - 1],
            primaryTag: behaviorData[i][COLUMNS_BEHAVIOR.PRIMARY_TAG - 1],
            allTags: behaviorData[i][COLUMNS_BEHAVIOR.ALL_TAGS - 1],
            interestLevel: behaviorData[i][COLUMNS_BEHAVIOR.INTEREST_LEVEL - 1]
          }
        });
      }
    }

    if (pending.length === 0) {
      logger.log("INFO", "No pending summaries for AI");
      return;
    }

    logger.log("START", { pending: pending.length, max_per_run: CONFIG.MAX_AI_PER_RUN });
    let processed = 0;
    const aiBudgetStart = Date.now();
    const AI_BUDGET_MS = 90000;

    for (let i = 0; i < pending.length; i += CONFIG.AI_BATCH_SIZE) {
      if (!isTimeRemaining(30000) || (Date.now() - aiBudgetStart) > AI_BUDGET_MS) {
        logger.log("TIMEOUT", `Stopped at ${i}/${pending.length}`);
        break;
      }

      const batch = pending.slice(i, i + CONFIG.AI_BATCH_SIZE);
      let results = inferBatchOnAggregates(batch, logger);

      if (results.rateLimited) {
        logger.log("RATE_LIMITED", "Gemini quota exceeded. Waiting...");
        Utilities.sleep(CONFIG.GEMINI_RATE_LIMIT_PAUSE);
        results = inferBatchOnAggregates(batch, logger);
      }

      results.data.forEach((result, idx) => {
        const behaviorRowIndex = batch[idx].index;
        const email = batch[idx].email;
        if (result.valid) {
          behaviorSheet.getRange(behaviorRowIndex, COLUMNS_BEHAVIOR.AVG_SCORE).setValue(result.score);
          const contactRowIndex = emailToContactRow[email];
          if (contactRowIndex) {
            contactsSheet.getRange(contactRowIndex, COLUMNS_CONTACTS.AI_SCORE).setValue(result.score);
            contactsSheet.getRange(contactRowIndex, COLUMNS_CONTACTS.AI_TAG).setValue(result.tag);
          }
          processed++;
        } else {
          logger.log("INFERENCE_FAILED", { email, error: result.error });
        }
      });

      SpreadsheetApp.flush();
      logger.log("BATCH", { batch_num: Math.floor(i / CONFIG.AI_BATCH_SIZE) + 1, processed });
    }

    logger.log("COMPLETE", { processed, total: pending.length });

  } catch (error) {
    logger.log("ERROR", { error: error.message });
    throw error;
  }
}

function inferBatchOnAggregates(rowsData, logger) {
  if (!CONFIG.gemini_key) {
    return { valid: false, error: "No API key", rateLimited: false, data: [] };
  }

  const requests = rowsData.map(item => ({
    url: `${CONFIG.GEMINI_API_BASE}/${CONFIG.gemini_model}:generateContent`,
    method: "POST",
    headers: { "x-goog-api-key": CONFIG.gemini_key, "Content-Type": "application/json" },
    payload: JSON.stringify({
      contents: [{
        parts: [{
          text: `Analyze this lead's behavioral summary to determine buying intent and engagement.

Email: ${item.email}
Activity Count: ${item.summary.activityCount} interactions
Interest Level: ${item.summary.interestLevel}
Primary Tag: ${item.summary.primaryTag}
All Tags: ${item.summary.allTags}

Respond ONLY with valid JSON (no markdown): {"score": <1-100 integer>, "tag": "<one_word_tag like erp, crm, automation, ai, etc>"}`
        }]
      }],
      generationConfig: { response_mime_type: "application/json", maxOutputTokens: 200 }
    }),
    muteHttpExceptions: true
  }));

  try {
    const responses = UrlFetchApp.fetchAll(requests);
    const results = [];
    let rateLimited = false;

    responses.forEach(res => {
      if (res.getResponseCode() === 429) {
        rateLimited = true;
        results.push({ valid: false, error: "Rate limited" });
        return;
      }
      results.push(parseGeminiResponse(res));
    });

    return { rateLimited, data: results };

  } catch (error) {
    logger.log("FETCH_ERROR", error.message);
    return { rateLimited: false, data: rowsData.map(() => ({ valid: false, error: error.message })) };
  }
}

