test("Signal Dedup","Respects SIGNAL_LOOKBACK_ROWS limit",()=>{
  const headers=[new Array(11).fill("h")];
  const rows=Array.from({length:4000},(_,i)=>{const r=new Array(11).fill("");r[2]=`sig_${i}`;return r;});
  const sheet=createMockSheet("ActivityBig",[...headers,...rows]);
