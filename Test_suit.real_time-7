section("SUITE 5: mapHSPropertiesToRow");
// ════════════════════════════════════════════════════════════

test("Row Mapper","Produces 18-column row",()=>{
  const contact={id:"42",properties:{email:"test@x.com",firstname:"Bob",lastname:"Smith",company:"Acme",jobtitle:"CEO",industry:"Tech",country:"UK",hs_lead_status:"Active",continent:"Europe"}};
  const result=mapHSPropertiesToRow(contact);
  assertEqual(result.row.length,18);
});
test("Row Mapper","Email is lowercased",()=>{
  const c={id:"1",properties:{email:"TEST@EXAMPLE.COM",firstname:"A",lastname:"B",company:"",jobtitle:"",industry:"",country:"",hs_lead_status:"",continent:""}};
  const r=mapHSPropertiesToRow(c);
  assertEqual(r.email,"test@example.com");
  assertEqual(r.row[2],"test@example.com");
});
test("Row Mapper","HS Contact ID stored in column 18",()=>{
  const c={id:"hs_999",properties:{email:"a@b.com",firstname:"",lastname:"",company:"",jobtitle:"",industry:"",country:"",hs_lead_status:"",continent:""}};
  const r=mapHSPropertiesToRow(c);
  assertEqual(r.row[17],"hs_999");
});
test("Row Mapper","Status defaults to Pending",()=>{
  const c={id:"1",properties:{email:"a@b.com",firstname:"",lastname:"",company:"",jobtitle:"",industry:"",country:"",hs_lead_status:"",continent:""}};
  const r=mapHSPropertiesToRow(c);
  assertEqual(r.row[9],"Pending");
});
test("Row Mapper","Industry fallback to Unclassified",()=>{
  const c={id:"1",properties:{email:"a@b.com",firstname:"",lastname:"",company:"",jobtitle:"",industry:"",country:"",hs_lead_status:"",continent:""}};
  const r=mapHSPropertiesToRow(c);
  assertEqual(r.industry,"Unclassified");
});

