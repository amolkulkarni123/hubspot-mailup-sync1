section("SUITE 6: isContactRowStale");
// ════════════════════════════════════════════════════════════

function makeHSContact(overrides={}){
  return{id:"hs1",properties:{firstname:overrides.firstname||"Alice",lastname:overrides.lastname||"Smith",company:overrides.company||"Acme",jobtitle:overrides.jobtitle||"CEO",industry:overrides.industry||"Tech",country:overrides.country||"US",continent:"Americas",email:"alice@test.com",hs_lead_status:"Active"}};
}

test("Stale Check","Returns false when fields match",()=>{
  const sheetRow=makeContactRow({firstName:"Alice",lastName:"Smith",company:"Acme",industry:"Tech",country:"US"});
  assert(!isContactRowStale(sheetRow,makeHSContact()));
});
test("Stale Check","Returns true when firstname differs",()=>{
  const sheetRow=makeContactRow({firstName:"OldName",lastName:"Smith",company:"Acme",industry:"Tech",country:"US"});
  assert(isContactRowStale(sheetRow,makeHSContact({firstname:"Alice"})));
});
test("Stale Check","Returns true when company differs",()=>{
  const sheetRow=makeContactRow({firstName:"Alice",lastName:"Smith",company:"OldCorp",industry:"Tech",country:"US"});
  assert(isContactRowStale(sheetRow,makeHSContact({company:"Acme"})));
});
test("Stale Check","Returns true when industry differs",()=>{
  const sheetRow=makeContactRow({firstName:"Alice",lastName:"Smith",company:"Acme",industry:"Finance",country:"US"});
  assert(isContactRowStale(sheetRow,makeHSContact({industry:"Tech"})));
});

// ════════════════════════════════════════════════════════════
section("SUITE 7: upsertContactRow");
// ════════════════════════════════════════════════════════════

test("Upsert","New email → row inserted",()=>{
  _sheets["Contacts"]=createMockSheet("Contacts",[COLUMN_HEADERS_CONTACTS]);
  const sheet=_sheets["Contacts"];
  const contactData=mapHSPropertiesToRow({id:"hs_new",properties:{email:"new@x.com",firstname:"New",lastname:"User",company:"Co",jobtitle:"",industry:"Tech",country:"US",hs_lead_status:"",continent:""}});
  upsertContactRow(sheet,contactData,"hs_new");
  assertEqual(sheet.getLastRow(),2);
});
test("Upsert","Existing email → row updated (not duplicated)",()=>{
  const headers=COLUMN_HEADERS_CONTACTS;
  const existingRow=makeContactRow({email:"alice@test.com",hsId:"hs_alice",status:"Success"});
  _sheets["Contacts"]=createMockSheet("Contacts",[headers,existingRow]);
  const sheet=_sheets["Contacts"];
  const contactData=mapHSPropertiesToRow({id:"hs_alice",properties:{email:"alice@test.com",firstname:"Alice_Updated",lastname:"Smith",company:"NewCo",jobtitle:"CTO",industry:"Tech",country:"US",hs_lead_status:"",continent:""}});
  upsertContactRow(sheet,contactData,"hs_alice");
  assertEqual(sheet.getLastRow(),2,"Should not have added a new row");
});
test("Upsert","Status preserved on update",()=>{
  const headers=COLUMN_HEADERS_CONTACTS;
  const existingRow=makeContactRow({email:"alice@test.com",hsId:"hs_alice",status:"Success"});
  _sheets["Contacts"]=createMockSheet("Contacts",[headers,existingRow]);
  const sheet=_sheets["Contacts"];
  const contactData=mapHSPropertiesToRow({id:"hs_alice",properties:{email:"alice@test.com",firstname:"Alice",lastname:"Smith",company:"NewCo",jobtitle:"",industry:"Tech",country:"US",hs_lead_status:"",continent:""}});
  upsertContactRow(sheet,contactData,"hs_alice");
  const updated=sheet.getRange(2,COLUMNS_CONTACTS.STATUS,1,1).getValues()[0][0];
  assertEqual(updated,"Success","Status should be preserved, not reset to Pending");
});

// ════════════════════════════════════════════════════════════
section("SUITE 8: Webhook Event Processing");
// ════════════════════════════════════════════════════════════

// Reset sheets for webhook tests
function resetSheetsForWebhook(){
  _sheets["Contacts"]=createMockSheet("Contacts",[COLUMN_HEADERS_CONTACTS]);
  _sheets["Webhook Events"]=createMockSheet("Webhook Events",[COLUMN_HEADERS_EVENTS]);
  delete _scriptProps["PROCESSED_EVENT_IDS"];
  // Mock fetchWithBackoff via UrlFetchApp.fetch returning a valid contact
  ctx.UrlFetchApp={
    fetch:()=>({getResponseCode:()=>200,getContentText:()=>JSON.stringify({id:"hs_001",properties:{email:"test@x.com",firstname:"Test",lastname:"User",company:"Co",jobtitle:"Dev",industry:"Tech",country:"US",hs_lead_status:"Active",continent:"Americas"}})}),
    fetchAll:(reqs)=>reqs.map(()=>({getResponseCode:()=>200,getContentText:()=>'{}'}))
  };
}

test("Webhook","creation event → contact upserted",()=>{
  resetSheetsForWebhook();
  const events=[{eventId:"evt_001",subscriptionType:"contact.creation",objectId:"hs_001",propertyName:null,propertyValue:null}];
  const result=processHubSpotWebhookBatch(events);
  assertEqual(result.created,1);
  assertEqual(result.skipped,0);
});

test("Webhook","deletion event → contact soft-deleted",()=>{
  resetSheetsForWebhook();
  // Pre-populate contact
  const row=makeContactRow({email:"test@x.com",hsId:"hs_001",status:"Pending"});
  _sheets["Contacts"]._data.push(row);
  const events=[{eventId:"evt_002",subscriptionType:"contact.deletion",objectId:"hs_001"}];
  processHubSpotWebhookBatch(events);
  const status=_sheets["Contacts"]._data[1][COLUMNS_CONTACTS.STATUS-1];
  assertEqual(status,"Deleted");
});

test("Webhook","propertyChange on tracked property patches row",()=>{
  resetSheetsForWebhook();
  const row=makeContactRow({email:"test@x.com",hsId:"hs_001",firstName:"OldName"});
  _sheets["Contacts"]._data.push(row);
  const events=[{eventId:"evt_003",subscriptionType:"contact.propertyChange",objectId:"hs_001",propertyName:"firstname",propertyValue:"NewName"}];
  processHubSpotWebhookBatch(events);
  const firstname=_sheets["Contacts"]._data[1][COLUMNS_CONTACTS.FIRST_NAME-1];
  assertEqual(firstname,"NewName");
});

test("Webhook","Duplicate eventId skipped (idempotency)",()=>{
  resetSheetsForWebhook();
  const events=[{eventId:"evt_004",subscriptionType:"contact.creation",objectId:"hs_001"}];
  processHubSpotWebhookBatch(events);  // first time
  const result=processHubSpotWebhookBatch(events);  // second time — should skip
  assertEqual(result.skipped,1);
});

test("Webhook","Empty event array returns 0 counts",()=>{
  resetSheetsForWebhook();
  const result=processHubSpotWebhookBatch([]);
  assertEqual(result.created,0);
  assertEqual(result.updated,0);
  assertEqual(result.deleted,0);
});

test("Webhook","Unknown subscriptionType increments skipped",()=>{
  resetSheetsForWebhook();
  const events=[{eventId:"evt_005",subscriptionType:"deal.creation",objectId:"deal_123"}];
  const result=processHubSpotWebhookBatch(events);
  assertEqual(result.skipped,1);
  assertEqual(result.created,0);
});

test("Webhook","Event logged to Webhook Events sheet",()=>{
  resetSheetsForWebhook();
  const events=[{eventId:"evt_006",subscriptionType:"contact.creation",objectId:"hs_001"}];
  processHubSpotWebhookBatch(events);
  const eventsSheet=_sheets["Webhook Events"];
  assert(eventsSheet.getLastRow()>=2,"Event should be logged");
});

test("Webhook","processedEventIds dedup set persists between calls",()=>{
  resetSheetsForWebhook();
  const events=[{eventId:"evt_007",subscriptionType:"contact.creation",objectId:"hs_001"}];
  processHubSpotWebhookBatch(events);
  const ids=getProcessedEventIds();
  assert(ids.has("evt_007"),"evt_007 should be in processed set");
});

