section("SUITE 9: handleContactDelete (soft delete)");
// ════════════════════════════════════════════════════════════

test("Soft Delete","Existing contact → Status = Deleted",()=>{
  _sheets["Contacts"]=createMockSheet("Contacts",[COLUMN_HEADERS_CONTACTS,makeContactRow({hsId:"del_001",status:"Success"})]);
  const {handleContactDelete:hcd}=ctx._EXPORTS;
  hcd("del_001");
  assertEqual(_sheets["Contacts"]._data[1][COLUMNS_CONTACTS.STATUS-1],"Deleted");
});

test("Soft Delete","Non-existent HS ID → no row added",()=>{
  _sheets["Contacts"]=createMockSheet("Contacts",[COLUMN_HEADERS_CONTACTS]);
  const before=_sheets["Contacts"].getLastRow();
  const {handleContactDelete:hcd}=ctx._EXPORTS;
  hcd("nonexistent_hs_id");
  assertEqual(_sheets["Contacts"].getLastRow(),before,"Should not add new rows");
});

test("Soft Delete","Message set to 'Deleted in HubSpot'",()=>{
  _sheets["Contacts"]=createMockSheet("Contacts",[COLUMN_HEADERS_CONTACTS,makeContactRow({hsId:"del_002"})]);
  const {handleContactDelete:hcd}=ctx._EXPORTS;
  hcd("del_002");
  assertEqual(_sheets["Contacts"]._data[1][COLUMNS_CONTACTS.MESSAGE-1],"Deleted in HubSpot");
});

