section("SUITE 17: Performance");
// ════════════════════════════════════════════════════════════

test("Perf","Sort 10k contacts < 100ms",()=>{
  const industries=["Tech","Finance","Health","Agriculture","Retail"];
  const buf=Array.from({length:10000},(_,i)=>({industry:industries[i%5],data:[]}));
  const t=Date.now();buf.sort((a,b)=>a.industry.localeCompare(b.industry));
  assert(Date.now()-t<100,`Took ${Date.now()-t}ms`);
});
test("Perf","buildEmailIndex for 5k rows < 50ms",()=>{
  const headers=[COLUMN_HEADERS_CONTACTS];
  const rows=Array.from({length:5000},(_,i)=>{const r=new Array(18).fill("");r[2]=`u${i}@x.com`;return r;});
  const sheet=createMockSheet("PerfC",[...headers,...rows]);
  const t=Date.now();buildEmailIndex(sheet);
  assert(Date.now()-t<50,`Took ${Date.now()-t}ms`);
});
test("Perf","buildHSIdIndex for 5k rows < 50ms",()=>{
  const headers=[COLUMN_HEADERS_CONTACTS];
  const rows=Array.from({length:5000},(_,i)=>{const r=new Array(18).fill("");r[17]=`hs_${i}`;return r;});
  const sheet=createMockSheet("PerfH",[...headers,...rows]);
  const t=Date.now();buildHSIdIndex(sheet);
  assert(Date.now()-t<50,`Took ${Date.now()-t}ms`);
});
test("Perf","Validate 1000 contacts < 200ms",()=>{
  const t=Date.now();
  for(let i=0;i<1000;i++)validateContactForMailUp(makeContactRow({email:`u${i}@x.com`}));
  assert(Date.now()-t<200,`Took ${Date.now()-t}ms`);
});

