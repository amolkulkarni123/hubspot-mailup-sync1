section("SUITE 10: Back-Sync (checkBackSyncAlreadyDone)");
// ════════════════════════════════════════════════════════════

test("Back-Sync","Returns false when sheet is empty",()=>{
  const sheet=createMockSheet("BS",[COLUMN_HEADERS_BACKSYNC]);
  assert(!checkBackSyncAlreadyDone(sheet,"alice@test.com"));
});
test("Back-Sync","Returns true when email already logged",()=>{
  const sheet=createMockSheet("BS",[COLUMN_HEADERS_BACKSYNC,[new Date(),"alice@test.com","Unsubscribed",true,"done"]]);
  assert(checkBackSyncAlreadyDone(sheet,"alice@test.com"));
});
test("Back-Sync","Case-insensitive email check",()=>{
  const sheet=createMockSheet("BS",[COLUMN_HEADERS_BACKSYNC,[new Date(),"ALICE@TEST.COM","Unsubscribed",true,"done"]]);
  assert(checkBackSyncAlreadyDone(sheet,"alice@test.com"));
});
test("Back-Sync","Returns false for different email",()=>{
  const sheet=createMockSheet("BS",[COLUMN_HEADERS_BACKSYNC,[new Date(),"other@test.com","Unsubscribed",true,"done"]]);
  assert(!checkBackSyncAlreadyDone(sheet,"alice@test.com"));
});

