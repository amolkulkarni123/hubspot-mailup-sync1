// FINAL REPORT
// ════════════════════════════════════════════════════════════

const total=passed+failed;
const failOnly=results.filter(r=>r.status==="FAIL");
const warnOnly=results.filter(r=>r.status==="WARN");

console.log(`
${"═".repeat(62)}
  FINAL TEST REPORT — hubspot_mailup_v7.0.js
${"═".repeat(62)}
  Total Tests : ${total}
  ✅ Passed   : ${passed}
  ❌ Failed   : ${failed}
  ⚠️  Warnings : ${warned}
${"═".repeat(62)}`);

if(failOnly.length>0){
  console.log("\n  ❌ FAILURES:");
  failOnly.forEach(f=>console.log(`     [${f.group}] ${f.name}\n       → ${f.error}`));
}
if(warnOnly.length>0){
  console.log("\n  ⚠️  WARNINGS:");
  warnOnly.forEach(w=>console.log(`     [${w.group}] ${w.name}\n       → ${w.error}`));
}

const ok=failed===0;
console.log(`
${"═".repeat(62)}
  VERDICT: ${ok?"✅ PRODUCTION READY":"❌ NOT PRODUCTION READY — fix failures above"}
${"═".repeat(62)}\n`);
process.exit(ok?0:1);
