section("SUITE 20: Fix B — Circular Buffer (Persistence Safety)");
// ════════════════════════════════════════════════════════════

test("Circular Buffer","saveProcessedEventIds caps at 400",()=>{
  delete _scriptProps["PROCESSED_EVENT_IDS"];
  // Build a set with 600 IDs
  const bigSet = new Set(Array.from({length:600},(_,i)=>`evt_${String(i).padStart(16,'0')}`));
  const {saveProcessedEventIds:save} = ctx._EXPORTS;
  save(bigSet);
  const stored = JSON.parse(_scriptProps["PROCESSED_EVENT_IDS"]);
  assertEqual(stored.length, 400, `Expected 400 IDs stored, got ${stored.length}`);
});

test("Circular Buffer","Keeps the MOST RECENT 400 (oldest dropped)",()=>{
  delete _scriptProps["PROCESSED_EVENT_IDS"];
  const ids = Array.from({length:600},(_,i)=>`evt_${String(i).padStart(4,'0')}`);
  const bigSet = new Set(ids);
  const {saveProcessedEventIds:save} = ctx._EXPORTS;
  save(bigSet);
  const stored = JSON.parse(_scriptProps["PROCESSED_EVENT_IDS"]);
  // Last 400 = ids[200] through ids[599]
  assertEqual(stored[0], "evt_0200", "Oldest kept should be evt_0200");
  assertEqual(stored[399], "evt_0599", "Newest kept should be evt_0599");
});

test("Circular Buffer","Stored JSON stays under 9216 bytes (9KB limit)",()=>{
  delete _scriptProps["PROCESSED_EVENT_IDS"];
  // Worst case: 16-digit IDs (longest realistic HubSpot eventId)
  const worstCase = new Set(Array.from({length:400},(_,i)=>`${String(i).padStart(16,'0')}`));
  const {saveProcessedEventIds:save} = ctx._EXPORTS;
  save(worstCase);
  const byteSize = Buffer.byteLength(_scriptProps["PROCESSED_EVENT_IDS"], 'utf8');
  assert(byteSize < 9216, `Stored JSON is ${byteSize} bytes — exceeds 9216-byte PropertiesService limit`);
});

test("Circular Buffer","Small set (< 400) stored in full — no truncation",()=>{
  delete _scriptProps["PROCESSED_EVENT_IDS"];
  const smallSet = new Set(["evt_001","evt_002","evt_003"]);
  const {saveProcessedEventIds:save} = ctx._EXPORTS;
  save(smallSet);
  const stored = JSON.parse(_scriptProps["PROCESSED_EVENT_IDS"]);
  assertEqual(stored.length, 3, "All 3 IDs should be stored");
});

test("Circular Buffer","Empty set stores empty array",()=>{
  delete _scriptProps["PROCESSED_EVENT_IDS"];
  const {saveProcessedEventIds:save} = ctx._EXPORTS;
  save(new Set());
  const stored = JSON.parse(_scriptProps["PROCESSED_EVENT_IDS"]);
  assertEqual(stored.length, 0);
});

test("Circular Buffer","Roundtrip: save then getProcessedEventIds recovers all IDs",()=>{
  delete _scriptProps["PROCESSED_EVENT_IDS"];
  const ids = new Set(["alpha","beta","gamma"]);
  const {saveProcessedEventIds:save, getProcessedEventIds:get} = ctx._EXPORTS;
  save(ids);
  const recovered = get();
  assert(recovered.has("alpha") && recovered.has("beta") && recovered.has("gamma"));
  assertEqual(recovered.size, 3);
});

