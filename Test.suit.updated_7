section("SUITE 2: Row Lookup by HS Contact ID");
// ════════════════════════════════════════════════════════════

function setupContactSheet(){
  const headers=COLUMN_HEADERS_CONTACTS;
  const rows=[
    headers,
    makeContactRow({email:"alice@test.com",hsId:"hs_alice"}),
    makeContactRow({email:"bob@test.com",  hsId:"hs_bob"}),
    makeContactRow({email:"carol@test.com",hsId:"hs_carol"})
  ];
  _sheets["Contacts"]=createMockSheet("Contacts",rows);
  return _sheets["Contacts"];
}

test("HS ID Lookup","Finds row by exact HS ID",()=>{
  const sheet=setupContactSheet();
  const row=getContactRowByHSId(sheet,"hs_alice");
  assertEqual(row,2);
});
test("HS ID Lookup","Returns null for missing HS ID",()=>{
  const sheet=setupContactSheet();
  assert(getContactRowByHSId(sheet,"hs_nonexistent")===null);
});
test("HS ID Lookup","Finds bob at row 3",()=>{
  const sheet=setupContactSheet();
  assertEqual(getContactRowByHSId(sheet,"hs_bob"),3);
});
test("HS ID Lookup","Returns null for empty id",()=>{
  const sheet=setupContactSheet();
  assert(getContactRowByHSId(sheet,"")===null);
});
test("HS ID Lookup","Returns null on empty sheet",()=>{
  const empty=createMockSheet("EmptyC",[]);
  assert(getContactRowByHSId(empty,"hs_001")===null);
});

// ════════════════════════════════════════════════════════════
section("SUITE 3: Row Lookup by Email");
// ════════════════════════════════════════════════════════════

test("Email Lookup","Finds row by email",()=>{
  const sheet=setupContactSheet();
  assertEqual(getContactRowByEmail(sheet,"alice@test.com"),2);
});
test("Email Lookup","Case-insensitive match",()=>{
  const sheet=setupContactSheet();
  assertEqual(getContactRowByEmail(sheet,"ALICE@TEST.COM"),2);
});
test("Email Lookup","Returns null for missing email",()=>{
  const sheet=setupContactSheet();
  assert(getContactRowByEmail(sheet,"nobody@test.com")===null);
});
test("Email Lookup","Returns null on empty sheet",()=>{
  const empty=createMockSheet("EmptyC2",[]);
  assert(getContactRowByEmail(empty,"x@x.com")===null);
});

