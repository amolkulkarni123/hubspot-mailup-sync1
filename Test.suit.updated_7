section("SUITE 13: Preserved — Segment Word-Boundary Fix");
// ════════════════════════════════════════════════════════════

function getSegment(tag){
  const t=(tag||"").trim().toLowerCase();
  if(!t)return"Unclassified";
  for(const[key,name]of Object.entries(SEGMENT_MAP)){
    if(new RegExp(`(^|[_\\-\\s,])${key}([_\\-\\s,]|$)`).test(t)||t===key){return name;}
  }
  return"General";
}

test("Segments","erp → ERP Buyers",()=>assertEqual(getSegment("erp"),"ERP Buyers"));
test("Segments","ai → AI Automation",()=>assertEqual(getSegment("ai"),"AI Automation"));
test("Segments","'main' does NOT match ai",()=>assertEqual(getSegment("main"),"General"));
test("Segments","'email' does NOT match ai",()=>assertEqual(getSegment("email"),"General"));
test("Segments","'detail' does NOT match ai",()=>assertEqual(getSegment("detail"),"General"));
test("Segments","'gmail' does NOT match ai",()=>assertEqual(getSegment("gmail"),"General"));
test("Segments","'retail' does NOT match ai",()=>assertEqual(getSegment("retail"),"General"));
test("Segments","'ai_automation' matches automation (automation key precedes ai in map)",()=>assertEqual(getSegment("ai_automation"),"Automation Leads"));
test("Segments","standalone 'ai' still matches AI Automation",()=>assertEqual(getSegment("ai"),"AI Automation"));
test("Segments","Unknown tag → General",()=>assertEqual(getSegment("unknown_xyz"),"General"));
test("Segments","null → Unclassified",()=>assertEqual(getSegment(null),"Unclassified"));

