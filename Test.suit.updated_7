section("SUITE 4: Index Builders");
// ════════════════════════════════════════════════════════════

test("Index Builder","buildEmailIndex returns correct map",()=>{
  const sheet=setupContactSheet();
  const idx=buildEmailIndex(sheet);
  assertEqual(idx["alice@test.com"],2);
  assertEqual(idx["bob@test.com"],3);
  assertEqual(idx["carol@test.com"],4);
});
test("Index Builder","buildHSIdIndex returns correct map",()=>{
  const sheet=setupContactSheet();
  const idx=buildHSIdIndex(sheet);
  assertEqual(idx["hs_alice"],2);
  assertEqual(idx["hs_bob"],3);
});
test("Index Builder","buildEmailIndex empty sheet = empty map",()=>{
  const empty=createMockSheet("E",[]);
  assertDeepEqual(buildEmailIndex(empty),{});
});

