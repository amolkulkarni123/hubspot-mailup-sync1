section("SUITE 21: Fix A — LockService (Concurrency Safety)");
// ════════════════════════════════════════════════════════════

// Helper: reset lock counters
function resetLockCounters(){ _lockCallCount=0; _lockReleaseCount=0; _lockShouldTimeout=false; }

test("LockService","doPost acquires lock on every call",()=>{
  resetLockCounters();
  _lockShouldTimeout = false;
  // Simulate a minimal valid doPost call
  const fakeE = {
    postData: { contents: JSON.stringify([{eventId:"lock_test_001",subscriptionType:"contact.creation",objectId:"hs_1"}]) },
    parameter: {}, headers: {}
  };
  _sheets["Contacts"] = createMockSheet("Contacts",[COLUMN_HEADERS_CONTACTS]);
  _sheets["Webhook Events"] = createMockSheet("Webhook Events",[COLUMN_HEADERS_EVENTS]);
  delete _scriptProps["PROCESSED_EVENT_IDS"];
  // doPost is in ctx — call it directly
  ctx.doPost(fakeE);
  assert(_lockCallCount >= 1, `Lock should have been called at least once, got ${_lockCallCount}`);
});

test("LockService","doPost releases lock even on success",()=>{
  resetLockCounters();
  _lockShouldTimeout = false;
  const fakeE = {
    postData: { contents: JSON.stringify([]) },
    parameter: {}, headers: {}
  };
  ctx.doPost(fakeE);
  assert(_lockReleaseCount >= 1, `Lock should be released after doPost, releases=${_lockReleaseCount}`);
});

test("LockService","doPost returns retry response when lock times out",()=>{
  resetLockCounters();
  _lockShouldTimeout = true;
  const fakeE = {
    postData: { contents: JSON.stringify([{eventId:"e1",subscriptionType:"contact.creation",objectId:"1"}]) },
    parameter: {}, headers: {}
  };
  const response = ctx.doPost(fakeE);
  // ContentService mock returns the string directly
  assert(response !== null && response !== undefined, "Should return a response even on timeout");
  _lockShouldTimeout = false; // reset
});

test("LockService","upsertContactRow acquires lock",()=>{
  resetLockCounters();
  _sheets["Contacts"] = createMockSheet("Contacts",[COLUMN_HEADERS_CONTACTS]);
  const sheet = _sheets["Contacts"];
  const contactData = ctx._EXPORTS.mapHSPropertiesToRow({
    id:"hs_lock_1",
    properties:{email:"lock@test.com",firstname:"Lock",lastname:"Test",company:"Co",jobtitle:"",industry:"Tech",country:"US",hs_lead_status:"",continent:""}
  });
  ctx._EXPORTS.upsertContactRow(sheet, contactData, "hs_lock_1");
  assert(_lockCallCount >= 1, `upsertContactRow should acquire lock, calls=${_lockCallCount}`);
  assert(_lockReleaseCount >= 1, `upsertContactRow should release lock, releases=${_lockReleaseCount}`);
});

test("LockService","upsertContactRow releases lock on exception path",()=>{
  resetLockCounters();
  // Pass a broken sheet that throws on getLastRow to trigger the catch path
  const brokenSheet = {
    getLastRow: () => { throw new Error("Simulated sheet error"); },
    getRange: () => ({ getValues: () => [[]], setValues: ()=>{} }),
    appendRow: ()=>{}
  };
  const contactData = ctx._EXPORTS.mapHSPropertiesToRow({
    id:"hs_err",
    properties:{email:"err@test.com",firstname:"",lastname:"",company:"",jobtitle:"",industry:"",country:"",hs_lead_status:"",continent:""}
  });
  try { ctx._EXPORTS.upsertContactRow(brokenSheet, contactData, "hs_err"); } catch(e){}
  // releaseLock must have been called (finally{} block)
  assert(_lockReleaseCount >= 1, `Lock must be released even on exception, releases=${_lockReleaseCount}`);
});

test("LockService","syncMailUpToSheets acquires lock",()=>{
  resetLockCounters();
  _lockShouldTimeout = false;
  // Override UrlFetchApp to return empty MailUp result so sync completes fast
  ctx.UrlFetchApp = {
    fetch: (url) => {
      if (url.includes("mailup")) return { getResponseCode:()=>200, getContentText:()=>JSON.stringify({Items:[]}) };
      if (url.includes("hubapi")) return { getResponseCode:()=>200, getContentText:()=>JSON.stringify({access_token:"tok",expires_in:3600}) };
      return { getResponseCode:()=>200, getContentText:()=>'{}' };
    },
    fetchAll: (reqs) => reqs.map(()=>({getResponseCode:()=>200,getContentText:()=>'{}'}))
  };
  _sheets["Contacts"] = createMockSheet("Contacts",[COLUMN_HEADERS_CONTACTS]);
  _sheets["Back-Sync Log"] = createMockSheet("Back-Sync Log",[COLUMN_HEADERS_BACKSYNC]);
  ctx.syncMailUpToSheets();
  assert(_lockCallCount >= 1, `syncMailUpToSheets must acquire lock, calls=${_lockCallCount}`);
  assert(_lockReleaseCount >= 1, `syncMailUpToSheets must release lock, releases=${_lockReleaseCount}`);
});

test("LockService","syncMailUpToSheets skips gracefully when lock unavailable",()=>{
  resetLockCounters();
  _lockShouldTimeout = true;
  const before = _lockReleaseCount;
  ctx.syncMailUpToSheets();
  // Should return early — no release needed because lock was never held
  assertEqual(_lockReleaseCount, before, "Should not call releaseLock if tryLock returned false");
  _lockShouldTimeout = false;
});

test("LockService","syncSheetsToHubSpot acquires lock",()=>{
  resetLockCounters();
  _lockShouldTimeout = false;
  ctx.UrlFetchApp = {
    fetch: () => ({ getResponseCode:()=>200, getContentText:()=>'{}' }),
    fetchAll: (reqs) => reqs.map(()=>({getResponseCode:()=>200,getContentText:()=>'{}'}))
  };
  _sheets["Contacts"] = createMockSheet("Contacts",[COLUMN_HEADERS_CONTACTS]);
  _sheets["Back-Sync Log"] = createMockSheet("Back-Sync Log",[COLUMN_HEADERS_BACKSYNC]);
  ctx.syncSheetsToHubSpot();
  assert(_lockCallCount >= 1, `syncSheetsToHubSpot must acquire lock, calls=${_lockCallCount}`);
  assert(_lockReleaseCount >= 1, `syncSheetsToHubSpot must release lock, releases=${_lockReleaseCount}`);
});

test("LockService","syncSheetsToHubSpot skips gracefully when lock unavailable",()=>{
  resetLockCounters();
  _lockShouldTimeout = true;
  ctx.syncSheetsToHubSpot();
  assertEqual(_lockReleaseCount, 0, "Must not release a lock that was never acquired");
  _lockShouldTimeout = false;
});

