/**
 * TEST SUITE — v7.1 Enterprise Hardened Script
 * All 99 v7.0 tests + new suites for Fix A (Mutex) and Fix B (Circular Buffer)
 */

const vm = require('vm');
const fs = require('fs');
let src = fs.readFileSync('/home/claude/v72.js', 'utf8');

// ─── zero-dep test framework ───────────────────────────────
let passed=0, failed=0, warned=0;
const results=[];
function test(group,name,fn){
  try{fn();passed++;results.push({status:"PASS",group,name});process.stdout.write(`  ✅ ${name}\n`);}
  catch(e){failed++;results.push({status:"FAIL",group,name,error:e.message});process.stdout.write(`  ❌ ${name}\n     → ${e.message}\n`);}
}
function warn(group,name,msg){warned++;results.push({status:"WARN",group,name,error:msg});process.stdout.write(`  ⚠️  ${name}\n     → ${msg}\n`);}
function assert(c,m){if(!c)throw new Error(m||"Assertion failed");}
function assertEqual(a,b,m){if(a!==b)throw new Error(m||`Expected ${JSON.stringify(b)}, got ${JSON.stringify(a)}`);}
function assertDeepEqual(a,b,m){if(JSON.stringify(a)!==JSON.stringify(b))throw new Error(m||`Expected ${JSON.stringify(b)}, got ${JSON.stringify(a)}`);}
function section(t){console.log(`\n${"═".repeat(62)}\n  ${t}\n${"═".repeat(62)}`);}

// ─── GAS mocks ────────────────────────────────────────────
const _scriptProps={};
const _sheets={};
let _flushCalled=false;
let _appendRowCalls=[];

function createMockSheet(name,rows=[]){
  const data=[...rows];
  return{
    name,_data:data,
    getLastRow:()=>data.length,
    appendRow:(row)=>{data.push(row);_appendRowCalls.push({sheet:name,row});},
    getRange:(row,col,numRows,numCols)=>({
      getValues:()=>{const r=[];for(let i=0;i<(numRows||1);i++){const ra=[];for(let j=0;j<(numCols||1);j++){const d=data[row-1+i];ra.push(d?(d[col-1+j]!==undefined?d[col-1+j]:''):'');}r.push(ra);}return r;},
      setValues:(vals)=>{vals.forEach((r,i)=>{while(data.length<row-1+i)data.push([]);data[row-1+i]=r;});},
      setValue:(val)=>{while(data.length<row)data.push([]);if(!data[row-1])data[row-1]=[];data[row-1][col-1]=val;},
      setBackground:()=>{}
    }),
    getRangeList:()=>({setBackground:()=>{}}),
    getDataRange:()=>({getValues:()=>data}),
    setFrozenRows:()=>{},
    deleteRows:(start,count)=>{data.splice(start-1,count);}
  };
}

const PropertiesService={getScriptProperties:()=>({
  getProperty:(k)=>_scriptProps[k]||null,
  setProperty:(k,v)=>{_scriptProps[k]=v;},
  deleteAllProperties:()=>{Object.keys(_scriptProps).forEach(k=>delete _scriptProps[k]);}
})};

const SpreadsheetApp={
  getActiveSpreadsheet:()=>({
    getSheetByName:(n)=>_sheets[n]||null,
    insertSheet:(n)=>{_sheets[n]=createMockSheet(n);return _sheets[n];},
    setActiveSheet:()=>{}
  }),
  flush:()=>{_flushCalled=true;},
  getUi:()=>({alert:()=>{},ButtonSet:{YES_NO:0},Button:{YES:0},createMenu:()=>({addItem:()=>({addItem:()=>({addItem:()=>({addSeparator:()=>({addSubMenu:()=>({addItem:()=>({addToUi:()=>{}})})})})})})})}),
};

const Utilities={sleep:()=>{},base64Encode:(s)=>Buffer.from(s).toString('base64'),
  computeHmacSha256Signature:(src,key)=>Array(32).fill(0)};
const UrlFetchApp={
  fetch:()=>({getResponseCode:()=>200,getContentText:()=>'{}'}),
  fetchAll:(reqs)=>reqs.map(()=>({getResponseCode:()=>200,getContentText:()=>'{}'}))
};
const HtmlService={createHtmlOutput:(h)=>h};
const ScriptApp={
  newTrigger:(fn)=>({timeBased:()=>({everyHours:()=>({create:()=>{}}),everyDays:()=>({atHour:()=>({create:()=>{}})})}) }),
  getProjectTriggers:()=>[],
  deleteTrigger:()=>{}
};
// ✅ LockService mock — tracks lock/release calls and simulates timeout behaviour
let _lockCallCount = 0;
let _lockReleaseCount = 0;
let _lockShouldTimeout = false;
const LockService = {
  getScriptLock: () => ({
    tryLock:   (ms) => { _lockCallCount++;   return !_lockShouldTimeout; },
    waitLock:  (ms) => { _lockCallCount++;   if (_lockShouldTimeout) throw new Error("Lock timeout"); },
    releaseLock: ()  => { _lockReleaseCount++; }
  })
};
const ContentService={
  createTextOutput:(s)=>({setMimeType:()=>({toString:()=>s})}),
  MimeType:{JSON:"application/json"}
};

// ─── Load script ──────────────────────────────────────────
src += `\nvar _EXPORTS = {
  isValidEmail, validateContactForMailUp, validateSignal, buildMailUpFields,
  parseGeminiResponse, getExistingEmails, getExistingSignalIds,
  getOrCreateSheet, safeWriteToSheet, isTimeRemaining, pushToDLQ,
  STATE, CONFIG, aggregateSignalsByLead, assignSegments,
  COLUMNS_CONTACTS, COLUMNS_ACTIVITY, COLUMNS_BEHAVIOR,
  COLUMN_HEADERS_CONTACTS, COLUMN_HEADERS_EVENTS, COLUMN_HEADERS_BACKSYNC,
  SEGMENT_MAP, GAP_DETECTION_CONFIG, MAILUP_FIELD_IDS, LOG_LEVELS,
  TRACKED_HS_PROPERTIES, MAILUP_STATUS,
  getContactRowByHSId, getContactRowByEmail, buildEmailIndex, buildHSIdIndex,
  upsertContactRow, mapHSPropertiesToRow, isContactRowStale, patchContactRow,
  processHubSpotWebhookBatch, handleContactCreate, handleContactUpdate,
  handleContactDelete, getProcessedEventIds, saveProcessedEventIds,
  checkBackSyncAlreadyDone, updateHubSpotContact,
  verifyHubSpotSignature,
  pushLocalChangeToHubSpot, pushSelectedRowToHubSpot, onEdit
};\n`;

const ctx={
  PropertiesService,SpreadsheetApp,Utilities,UrlFetchApp,HtmlService,ScriptApp,ContentService,LockService,
  console,Date,JSON,Math,Object,Array,Set,Map,String,Number,Boolean,RegExp,Error,Buffer,
  setTimeout,clearTimeout,encodeURIComponent
};
vm.createContext(ctx);
try{ vm.runInContext(src,ctx); }
catch(e){ console.error("FATAL: Script failed to load:",e.message,e.stack); process.exit(1); }

const {
  isValidEmail, validateContactForMailUp, validateSignal, buildMailUpFields,
  parseGeminiResponse, getExistingEmails, getExistingSignalIds,
  getOrCreateSheet, safeWriteToSheet, isTimeRemaining, pushToDLQ,
  STATE, CONFIG, aggregateSignalsByLead, assignSegments,
  COLUMNS_CONTACTS, COLUMNS_ACTIVITY, COLUMNS_BEHAVIOR,
  COLUMN_HEADERS_CONTACTS, COLUMN_HEADERS_EVENTS, COLUMN_HEADERS_BACKSYNC,
  SEGMENT_MAP, GAP_DETECTION_CONFIG, MAILUP_FIELD_IDS, LOG_LEVELS,
  TRACKED_HS_PROPERTIES, MAILUP_STATUS,
  getContactRowByHSId, getContactRowByEmail, buildEmailIndex, buildHSIdIndex,
  upsertContactRow, mapHSPropertiesToRow, isContactRowStale, patchContactRow,
  processHubSpotWebhookBatch, handleContactCreate, handleContactUpdate,
  handleContactDelete, getProcessedEventIds, saveProcessedEventIds,
  checkBackSyncAlreadyDone
} = ctx._EXPORTS;

// Bind new v7.2 functions onto ctx so tests can call them as ctx.fnName()
ctx.pushLocalChangeToHubSpot = ctx._EXPORTS.pushLocalChangeToHubSpot;
ctx.pushSelectedRowToHubSpot = ctx._EXPORTS.pushSelectedRowToHubSpot;
ctx.onEdit                   = ctx._EXPORTS.onEdit;
ctx.syncMailUpToSheets       = ctx._EXPORTS.syncMailUpToSheets || ctx.syncMailUpToSheets;
ctx.syncSheetsToHubSpot      = ctx._EXPORTS.syncSheetsToHubSpot || ctx.syncSheetsToHubSpot;

// helpers
function makeContactRow(overrides={}){
  const row=new Array(18).fill("");
  row[0]=overrides.firstName!==undefined?overrides.firstName:"John";
  row[1]=overrides.lastName!==undefined?overrides.lastName:"Doe";
  row[2]=overrides.email!==undefined?overrides.email:"john@example.com";
  row[3]=overrides.company!==undefined?overrides.company:"Acme";
  row[4]=overrides.jobTitle!==undefined?overrides.jobTitle:"Manager";
  row[5]=overrides.industry!==undefined?overrides.industry:"Tech";
  row[6]=overrides.country!==undefined?overrides.country:"US";
  row[7]=overrides.region!==undefined?overrides.region:"NA";
  row[8]=overrides.continent!==undefined?overrides.continent:"Americas";
  row[9]=overrides.status!==undefined?overrides.status:"Pending";
  row[17]=overrides.hsId!==undefined?overrides.hsId:"hs_001";
  return row;
}

function makeMockRes(text){return{getContentText:()=>text,getResponseCode:()=>200};}
function makeGeminiPayload(inner){return JSON.stringify({candidates:[{content:{parts:[{text:inner}]}}]});}
function makeSignal(overrides={}){return{id:overrides.id!==undefined?overrides.id:"sig_001",properties:{hs_communication_channel_type:overrides.channelType!==undefined?overrides.channelType:"EMAIL",hs_communication_logged_from:overrides.loggedFrom!==undefined?overrides.loggedFrom:"crm",hs_timestamp:overrides.timestamp!==undefined?overrides.timestamp:new Date().toISOString(),hs_communication_subject:overrides.subject!==undefined?overrides.subject:"Demo"}};}

// ════════════════════════════════════════════════════════════
section("SUITE 1: Schema — v7.0 column additions");
// ════════════════════════════════════════════════════════════

test("Schema","COLUMN_HEADERS_CONTACTS has 18 columns",()=>assertEqual(COLUMN_HEADERS_CONTACTS.length,18));
test("Schema","Column 18 = HS Contact ID",()=>assertEqual(COLUMN_HEADERS_CONTACTS[17],"HS Contact ID"));
test("Schema","COLUMNS_CONTACTS.HS_CONTACT_ID = 18",()=>assertEqual(COLUMNS_CONTACTS.HS_CONTACT_ID,18));
test("Schema","All other columns unchanged vs v6.7",()=>{
  assertEqual(COLUMNS_CONTACTS.EMAIL,3);
  assertEqual(COLUMNS_CONTACTS.STATUS,10);
  assertEqual(COLUMNS_CONTACTS.AI_SEGMENT,17);
});
test("Schema","COLUMN_HEADERS_EVENTS has 8 columns",()=>assertEqual(COLUMN_HEADERS_EVENTS.length,8));
test("Schema","COLUMN_HEADERS_BACKSYNC has 5 columns",()=>assertEqual(COLUMN_HEADERS_BACKSYNC.length,5));
test("Schema","No duplicate contact headers",()=>{const u=new Set(COLUMN_HEADERS_CONTACTS);assertEqual(u.size,18);});
test("Schema","MAILUP_STATUS constants defined",()=>{assert(MAILUP_STATUS.UNSUBSCRIBED===2);assert(MAILUP_STATUS.BOUNCED===4);});
test("Schema","TRACKED_HS_PROPERTIES is a Set",()=>{assert(TRACKED_HS_PROPERTIES instanceof Set);});
test("Schema","email, firstname, industry are tracked",()=>{
  assert(TRACKED_HS_PROPERTIES.has("email"));
  assert(TRACKED_HS_PROPERTIES.has("firstname"));
  assert(TRACKED_HS_PROPERTIES.has("industry"));
});
test("Schema","irrelevant properties not tracked",()=>{
  assert(!TRACKED_HS_PROPERTIES.has("hs_pipeline_stage"));
  assert(!TRACKED_HS_PROPERTIES.has("notes"));
});

